    "                placeholder = \"e.g. Explain quadratic equations with examples...\",\n",
    "                label       = \"Your Question\",\n",
    "                lines       = 2, scale=3\n",
    "            )\n",
    "\n",
    "        generate_btn = gr.Button(\"🚀 Generate Personalized Content\",\n",
    "                                 variant=\"primary\", size=\"lg\")\n",
    "\n",
    "        with gr.Row():\n",
    "            text_out = gr.Markdown(label=\"📚 Content\")\n",
    "\n",
    "        with gr.Row():\n",
    "            gallery_out = gr.Gallery(\n",
    "                label   = \"📊 Charts & Infographics\",\n",
    "                columns = 2, height=380\n",
    "            )\n",
    "\n",
    "        exercises_out = gr.Markdown(label=\"💪 Practice Exercises\")\n",
    "        status_out    = gr.Markdown()\n",
    "\n",
    "        def run_generate(question, subject, profile):\n",
    "            # Fix: guard against None values from empty Gradio inputs\n",
    "            question = question or \"\"\n",
    "            subject  = subject  or \"mathematics\"\n",
