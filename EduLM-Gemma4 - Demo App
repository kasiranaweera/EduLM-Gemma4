    "            temperature=0.7, do_sample=True,\n",
    "            top_p=0.92, repetition_penalty=1.1,\n",
    "        )\n",
    "    raw = _tokenizer.decode(out[0], skip_special_tokens=True)\n",
    "    return raw.split(\"model\\n\")[-1].strip()"
