    "    # ---- Tab 2: Learn ----\n",
    "    with gr.Tab(\"💬 Step 2 — Ask EduLM-Gemma4\"):\n",
    "        gr.Markdown(\"### Ask any question — content adapts to your learning style\")\n",
    "\n",
