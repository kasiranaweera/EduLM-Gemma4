/edulm-ils-dataset\n   Files (5): ['dataset_summary.json', 'val.jsonl', 'test.jsonl', 'diversity_report.json', 'train.jsonl']\n\n============================================================\n  Base model  : /kaggle/input/models/google/gemma-4/transformers/gemma-4-e4b-it/1\n  LoRA path   : /kaggle/working/edulm-gemma4-e4b-lora\n  Dataset     : /kaggle/input/datasets/ranaweerakasi/edulm-ils-dataset\n============================================================\n","output_type":"stream"}],"execution_count":2},{"cell_type":"code","source":"# STEP 3: ILS Assessment Engine\nfrom dataclasses import dataclass\nfrom typing import Dict\n\n@dataclass\nclass ILSProfile:\n    active_reflective: int\n    sensing_intuitive: int\n    visual_verbal: int\n    sequential_global: int\n\n    def get_labels(self) -> Dict[str, str]:\n        return {\n            \"processing\":    \"Reflective\" if self.active_reflective > 0 else \"Active\",\n            \"perception\":    \"Intuitive\"  if self.sensing_intuitive > 0 else \"Sensing\",\n            \"input\":         \"Verbal\"     if self.visual_verbal > 0     else \"Visual\",\n            \"understanding\": \"Global\"     if self.sequential_global > 0 else \"Sequential\",\n        }\n\n    def content_weights(self) -> Dict[str, float]:\n        vis  = max(0, -self.visual_verbal)     / 11.0\n        act  = max(0, -self.active_reflective) / 11.0\n        sens = max(0, -self.sensing_intuitive) / 11.0\n        seq  = max(0, -self.sequential_global) / 11.0\n        return {\n            \"diagrams\":    round(0.3 + vis  * 0.7, 2),\n            \"charts\":      round(0.3 + vis  * 0.6, 2),\n            \"qa\":          round(0.3 + act  * 0.7, 2),\n            \"exercises\":   round(0.2 + act  * 0.6, 2),\n            \"notes\":       round(0.4 + sens * 0.6, 2),\n            \"step_by_step\":round(0.3 + seq  * 0.7, 2),\n        }\n\n    def build_system_prompt(self, subject: str) -> str:\n        labels  = self.get_labels()\n        weights = self.content_weights()\n        top3    = sorted(weights.items(), key=lambda x: x[1], reverse=True)[:3]\n        hints   = []\n        if labels[\"input\"] == \"Visual\":\n            hints.append(\"Use [DIAGRAM] and [CHART] blocks.\")\n        if labels[\"processing\"] == \"Active\":\n            hints.append(\"Include [EXERCISE] practice problems.\")\n        if labels[\"understanding\"] == \"Sequential\":\n            hints.append(\"Use numbered step-by-step structure.\")\n        else:\n            hints.append(\"Start with a big-picture overview.\")\n        if labels[\"perception\"] == \"Sensing\":\n            hints.append(\"Include concrete real-world examples.\")\n        else:\n            hints.append(\"Include theories and conceptual connections.\")\n\n        return (\n            f\"You are EduGemma, a personalized AI tutor for {subject}.\\n\\n\"\n            f\"LEARNER PROFILE:\\n\"\n            f\"- Processing: {labels['processing']}\\n\"\n            f\"- Perception: {labels['perception']}\\n\"\n            f\"- Input: {labels['input']}\\n\"\n            f\"- Understanding: {labels['understanding']}\\n\\n\"\n            f\"Top formats for this learner: {', '.join(p[0] for p in top3)}\\n\\n\"\n            + \"\\n\".join(hints)\n        )\n\n\nILS_QUESTIONS = [\n    (\"I understand something better after I:\",\n     \"Try it out (Active)\", \"Think it through (Reflective)\", \"active_reflective\", -1, 1),\n    (\"When I am learning new material I prefer:\",\n     \"Diagrams, charts, and visuals (Visual)\", \"Written text and explanations (Verbal)\",\n     \"visual_verbal\", -1, 1),\n    (\"I learn best when content is:\",\n     \"Step-by-step from basics (Sequential)\", \"Big picture overview first (Global)\",\n     \"sequential_global\", -1, 1),\n    (\"I prefer examples that are:\",\n     \"Concrete and real-world (Sensing)\", \"Abstract and theoretical (Intuitive)\",\n     \"sensing_intuitive\", -1, 1),\n    (\"In a study group I am more likely to:\",\n     \"Jump in and contribute ideas (Active)\", \"Sit back and listen first (Reflective)\",\n     \"active_reflective\", -1, 1),\n    (\"When solving a problem I tend to:\",\n     \"Work through it one step at a time (Sequential)\", \"See the solution then trace back (Global)\",\n     \"sequential_global\", -1, 1),\n    (\"I remember things better from:\",\n     \"Pictures, diagrams, and demonstrations (Visual)\", \"Spoken or written explanations (Verbal)\",\n     \"visual_verbal\", -1, 1),\n    (\"I find it easier to learn:\",\n     \"Facts and procedures (Sensing)\", \"Concepts and theories (Intuitive)\",\n     \"sensing_intuitive\", -1, 1),\n]\n\ndef compute_ils_from_answers(answers: Dict[str, int]) -> ILSProfile:\n    \"\"\"answers: {dimension: cumulative score}\"\"\"\n    return ILSProfile(\n        active_reflective = answers.get(\"active_reflective\", 0),\n        sensing_intuitive = answers.get(\"sensing_intuitive\", 0),\n        visual_verbal     = answers.get(\"visual_verbal\", 0),\n        sequential_global = answers.get(\"sequential_global\", 0),\n    )","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-19T20:39:36.901391Z","iopub.execute_input":"2026-05-19T20:39:36.901777Z","iopub.status.idle":"2026-05-19T20:39:36.918087Z","shell.execute_reply.started":"2026-05-19T20:39:36.901735Z","shell.execute_reply":"2026-05-19T20:39:36.917369Z"}},"outputs":[],"execution_count":3},{"cell_type":"code","source":"# STEP 4: Content Renderer\nimport re, json as json_lib\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom PIL import Image, ImageDraw, ImageFont\nfrom io import BytesIO\nimport base64\nfrom typing import List, Optional, Tuple, Any\n\nclass ContentRenderer:\n    PALETTE = [\"#4C9BE8\",\"#F4A261\",\"#2A9D8F\",\"#E76F51\",\"#8338EC\",\"#06D6A0\"]\n\n    def _dark_fig(self, w=10, h=5.5):\n        fig, ax = plt.subplots(figsize=(w, h))\n        fig.patch.set_facecolor('#0F1117')\n        ax.set_facecolor('#1A1D2E')\n        ax.tick_params(colors='#CCC', labelsize=10)\n        for sp in ['top','right']:   ax.spines[sp].set_visible(False)\n        for sp in ['bottom','left']: ax.spines[sp].set_color('#444')\n        return fig, ax\n\n    def render_chart(self, ctype: str, data: dict) -> Optional[Image.Image]:\n        try:\n            fig, ax = self._dark_fig()\n            ct     = ctype.strip().lower()\n            labels = data.get(\"labels\", [])\n            values = data.get(\"values\", [])\n            colors = self.PALETTE[:len(labels)]\n\n            if ct == \"bar\":\n                bars = ax.bar(labels, values, color=colors,\n                              edgecolor='white', linewidth=0.4, alpha=0.88)\n                ax.bar_label(bars, fmt='%.1f', color='white',\n                             fontsize=9, padding=3)\n            elif ct == \"line\":\n                series = data.get(\"series\", [{\"values\": values, \"name\": \"\"}])\n                x = list(range(len(labels)))\n                for i, s in enumerate(series):\n                    c = self.PALETTE[i % len(self.PALETTE)]\n                    ax.plot(x, s[\"values\"], marker='o', lw=2.5, color=c,\n                            label=s.get(\"name\",\"\"), markersize=5,\n                            markerfacecolor='white', markeredgecolor=c)\n                    ax.fill_between(x, s[\"values\"], alpha=0.1, color=c)\n                ax.set_xticks(x)\n                ax.set_xticklabels(labels, rotation=15, color='white')\n                if len(series) > 1:\n                    ax.legend(facecolor='#1A1D2E', labelcolor='white')\n            elif ct == \"pie\":\n                ax.pie(values, labels=labels, autopct='%1.1f%%',\n                       colors=colors, explode=[0.03]*len(labels),\n                       startangle=90,\n                       textprops={'color':'white'}, pctdistance=0.82)\n            elif ct == \"scatter\":\n                pts = data.get(\"points\", list(zip(range(len(values)), values)))\n                ax.scatter([p[0] for p in pts], [p[1] for p in pts],\n                           c=colors[0], s=80, alpha=0.85, edgecolors='white')\n\n            if t := data.get(\"title\"):\n                ax.set_title(t, color='white', fontsize=13,\n                             fontweight='bold', pad=10)\n            if y := data.get(\"ylabel\"):\n                ax.set_ylabel(y, color='#AAA')\n\n            plt.tight_layout()\n            buf = BytesIO()\n            fig.savefig(buf, format='png', bbox_inches='tight',\n                        facecolor='#0F1117', dpi=130)\n            plt.close(fig)\n            buf.seek(0)\n            return Image.open(buf).copy()\n        except Exception as e:\n            print(f\"Chart error: {e}\")\n            return None\n\n    def render_infographic(self, title: str, data: dict) -> Optional[Image.Image]:\n        try:\n            items = (data.get(\"concepts\") or data.get(\"laws\") or\n                     data.get(\"items\") or [])\n            if not items: return None\n            W, IH = 900, 90\n            H = 70 + len(items) * IH + 20\n            img  = Image.new(\"RGB\", (W, H), (15, 17, 23))\n            draw = ImageDraw.Draw(img)\n            try:\n                fB = ImageFont.truetype(\n                    \"/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf\", 20)\n                fR = ImageFont.truetype(\n                    \"/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf\", 13)\n            except:\n                fB = fR = ImageFont.load_default()\n\n            draw.rectangle([0,0,W,58], fill=(26,29,46))\n            draw.text((20,16), title, fill=(255,255,255), font=fB)\n\n            COLS = [\"#4C9BE8\",\"#F4A261\",\"#2A9D8F\",\"#E76F51\",\"#8338EC\"]\n            for i, item in enumerate(items):\n                y  = 70 + i * IH\n                ac = COLS[i % len(COLS)]\n                r,g,b = int(ac[1:3],16), int(ac[3:5],16), int(ac[5:7],16)\n                draw.rectangle([14, y, W-14, y+IH-6], fill=(26,29,46),\n                               outline=ac, width=1)\n                draw.rectangle([14, y, 26,   y+IH-6], fill=(r,g,b))\n                num  = str(item.get(\"num\", i+1))\n                name = item.get(\"name\",\"\")\n                desc = item.get(\"desc\", item.get(\"formula\",\n                               item.get(\"example\",\"\")))[:100]\n                draw.text((38, y+10), num,  fill=(r,g,b),          font=fB)\n                draw.text((72, y+10), name, fill=(255,255,255),     font=fB)\n                draw.text((72, y+38), desc, fill=(180,180,200),     font=fR)\n            return img\n        except Exception as e:\n            print(f\"Infographic error: {e}\")\n            return None\n\n    CHART_RE    = re.compile(r'\\[CHART:\\s*([^\\|]+)\\s*\\|\\s*(\\{[^\\]]+\\})\\]', re.DOTALL)\n    DIAGRAM_RE  = re.compile(r'\\[DIAGRAM:\\s*[^\\]]+\\]',                       re.DOTALL)\n    INFOG_RE    = re.compile(r'\\[INFOGRAPHIC:\\s*([^\\|]+)\\s*\\|\\s*(\\{[^\\]]+\\})\\]', re.DOTALL)\n    EXERCISE_RE = re.compile(r'\\[EXERCISE:\\s*([^\\|]+)\\s*\\|\\s*(.*?)\\]',       re.DOTALL)\n    NOTE_RE     = re.compile(r'\\[NOTE:\\s*(.*?)\\]',                            re.DOTALL)\n\n    def parse_and_render(self, text: str):\n        images, exercises, notes = [], [], []\n\n        for m in self.CHART_RE.finditer(text):\n            try:\n                img = self.render_chart(m.group(1),\n                                        json_lib.loads(m.group(2).strip()))\n                if img: images.append(img)\n            except: pass\n\n        for m in self.INFOG_RE.finditer(text):\n            try:\n                img = self.render_infographic(m.group(1).strip(),\n                                              json_lib.loads(m.group(2).strip()))\n                if img: images.append(img)\n            except: pass\n\n        for m in self.EXERCISE_RE.finditer(text):\n            exercises.append({\"difficulty\": m.group(1).strip(),\n                              \"question\":   m.group(2).strip()})\n        for m in self.NOTE_RE.finditer(text):\n            notes.append(m.group(1).strip())\n\n        clean = self.CHART_RE.sub(\"📊 *[Chart rendered below]*\", text)\n        clean = self.DIAGRAM_RE.sub(\"📐 *[Diagram]*\", clean)\n        clean = self.INFOG_RE.sub(\"🖼️ *[Infographic rendered below]*\", clean)\n        clean = self.EXERCISE_RE.sub(\n            lambda m: f\"\\n\\n> 💪 **Exercise ({m.group(1)}):** {m.group(2)}\\n\", clean)\n        clean = self.NOTE_RE.sub(\n            lambda m: f\"\\n\\n> 📌 **Key Concept:** {m.group(1)}\\n\", clean)\n\n        return clean.strip(), images, exercises, notes","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-19T20:39:36.919927Z","iopub.execute_input":"2026-05-19T20:39:36.920119Z","iopub.status.idle":"2026-05-19T20:39:40.797562Z","shell.execute_reply.started":"2026-05-19T20:39:36.920100Z","shell.execute_reply":"2026-05-19T20:39:40.796616Z"}},"outputs":[],"execution_count":4},{"cell_type":"code","source":"# STEP 5: Load Model\nimport gc\nimport torch\nfrom unsloth import FastLanguageModel\n\n# Free all VRAM before loading\ntorch.cuda.empty_cache()\ngc.collect()\nprint(f\"Free VRAM: {torch.cuda.mem_get_info()[0]/1e9:.1f} GB\")\n\nprint(\"⏳ Loading base model + LoRA together...\")\n\n# Load base model AND LoRA adapter in one call.\n# Unsloth handles Gemma4ClippableLinear internally — this avoids the\n# PeftModel.from_pretrained ValueError on unsupported target modules.\nif MODEL_PATH:\n    _model, _tokenizer = FastLanguageModel.from_pretrained(\n        model_name     = MODEL_PATH,   # LoRA adapter dir (has adapter_config.json)\n        max_seq_length = 512,\n        dtype          = None,\n        load_in_4bit   = True,\n        device_map     = \"cuda:0\",\n    )\n    print(f\"✅ Base model + LoRA loaded from {MODEL_PATH}\")\nelse:\n    _model, _tokenizer = FastLanguageModel.from_pretrained(\n        model_name     = BASE_MODEL,\n        max_seq_length = 512,\n        dtype          = None,\n        load_in_4bit   = True,\n        device_map     = \"cuda:0\",\n    )\n    print(\"⚠️  No LoRA found — using base model\")\n\nFastLanguageModel.for_inference(_model)\n_renderer = ContentRenderer()\nprint(\"✅ EduLM-Gemma4 ready!\")\n\n\ndef generate(question: str, subject: str, ils: ILSProfile,\n             max_tokens: int = 512):\n    system = ils.build_system_prompt(subject)\n    msgs   = [\n        {\"role\": \"system\", \"content\": system},\n        {\"role\": \"user\",   \"content\": f\"[Subject:{subject}]\\n{question}\"}\n    ]\n    prompt = _tokenizer.apply_chat_template(\n        msgs, tokenize=False, add_generation_prompt=True\n    )\n    inputs = _tokenizer(prompt, return_tensors=\"pt\").to(\"cuda\")\n    with torch.no_grad():\n        out = _model.generate(\n            **inputs, max_new_tokens=max_tokens,\n            temperature=0.7, do_sample=True,\n            top_p=0.92, repetition_penalty=1.1,\n        )\n    raw = _tokenizer.decode(out[0], skip_special_tokens=True)\n    return raw.split(\"model\\n\")[-1].strip()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-19T20:39:40.798667Z","iopub.execute_input":"2026-05-19T20:39:40.799088Z","iopub.status.idle":"2026-05-19T20:42:12.092899Z","shell.execute_reply.started":"2026-05-19T20:39:40.799053Z","shell.execute_reply":"2026-05-19T20:42:12.092069Z"}},"outputs":[{"name":"stdout","text":"🦥 Unsloth: Will patch your computer to enable 2x faster free finetuning.\n🦥 Unsloth Zoo will now patch everything to make training faster!\nFree VRAM: 15.5 GB\n⏳ Loading base model + LoRA together...\n==((====))==  Unsloth 2026.5.5: Fast Gemma4 patching. Transformers: 5.5.0.\n   \\\\   /|    Tesla T4. Num GPUs = 2. Max memory: 14.563 GB. Platform: Linux.\nO^O/ \\_/ \\    Torch: 2.10.0+cu128. CUDA: 7.5. CUDA Toolkit: 12.8. Triton: 3.6.0\n\\        /    Bfloat16 = FALSE. FA [Xformers = 0.0.35. FA2 = False]\n \"-____-\"     Free license: