    "    _ils_scores[dim] += score_a if choice == \"a\" else score_b\n",
    "\n",
    "def get_profile() -> ILSProfile:\n",
    "    return compute_ils_from_answers(_ils_scores)\n",
    "\n",
    "def profile_to_markdown(profile: ILSProfile) -> str:\n",
    "    labels  = profile.get_labels()\n",
    "    weights = profile.content_weights()\n",
    "    top3    = sorted(weights.items(), key=lambda x: x[1], reverse=True)[:3]\n",
    "\n",
    "    icons = {\n",
    "        \"Active\":\"⚡\",\"Reflective\":\"🤔\",\"Visual\":\"👁️\",\"Verbal\":\"📝\",\n",
    "        \"Sensing\":\"🔬\",\"Intuitive\":\"💡\",\"Sequential\":\"📋\",\"Global\":\"🌐\"\n",
    "    }\n",
    "    md = \"## 🎓 Your Learning Profile\\n\\n\"\n",
    "    md += \"| Dimension | Your Style | Preference |\\n\"\n",
    "    md += \"|-----------|-----------|------------|\\n\"\n",
    "    descs = {\n",
    "        \"Active\":\"Learns by doing and applying\",\n",
    "        \"Reflective\":\"Learns by thinking and observing\",\n",
    "        \"Visual\":\"Prefers diagrams and charts\",\n",
    "        \"Verbal\":\"Prefers text and explanations\",\n",
    "        \"Sensing\":\"Prefers facts and examples\",\n",
    "        \"Intuitive\":\"Prefers theories and concepts\",\n",
    "        \"Sequential\":\"Step-by-step structure\",\n",
    "        \"Global\":\"Big picture first\",\n",
