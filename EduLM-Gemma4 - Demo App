    "# STEP 3: ILS Assessment Engine\n",
    "from dataclasses import dataclass\n",
    "from typing import Dict\n",
    "\n",
    "@dataclass\n",
    "class ILSProfile:\n",
    "    active_reflective: int\n",
    "    sensing_intuitive: int\n",
    "    visual_verbal: int\n",
    "    sequential_global: int\n",
    "\n",
    "    def get_labels(self) -> Dict[str, str]:\n",
    "        return {\n",
    "            \"processing\":    \"Reflective\" if self.active_reflective > 0 else \"Active\",\n",
    "            \"perception\":    \"Intuitive\"  if self.sensing_intuitive > 0 else \"Sensing\",\n",
    "            \"input\":         \"Verbal\"     if self.visual_verbal > 0     else \"Visual\",\n",
    "            \"understanding\": \"Global\"     if self.sequential_global > 0 else \"Sequential\",\n",
    "        }\n",
    "\n",
    "    def content_weights(self) -> Dict[str, float]:\n",
    "        vis  = max(0, -self.visual_verbal)     / 11.0\n",
    "        act  = max(0, -self.active_reflective) / 11.0\n",
    "        sens = max(0, -self.sensing_intuitive) / 11.0\n",
    "        seq  = max(0, -self.sequential_global) / 11.0\n",
    "        return {\n",
    "            \"diagrams\":    round(0.3 + vis  * 0.7, 2),\n",
    "            \"charts\":      round(0.3 + vis  * 0.6, 2),\n",
    "            \"qa\":          round(0.3 + act  * 0.7, 2),\n",
    "            \"exercises\":   round(0.2 + act  * 0.6, 2),\n",
    "            \"notes\":       round(0.4 + sens * 0.6, 2),\n",
    "            \"step_by_step\":round(0.3 + seq  * 0.7, 2),\n",
    "        }\n",
    "\n",
    "    def build_system_prompt(self, subject: str) -> str:\n",
    "        labels  = self.get_labels()\n",
    "        weights = self.content_weights()\n",
    "        top3    = sorted(weights.items(), key=lambda x: x[1], reverse=True)[:3]\n",
    "        hints   = []\n",
    "        if labels[\"input\"] == \"Visual\":\n",
    "            hints.append(\"Use [DIAGRAM] and [CHART] blocks.\")\n",
    "        if labels[\"processing\"] == \"Active\":\n",
    "            hints.append(\"Include [EXERCISE] practice problems.\")\n",
    "        if labels[\"understanding\"] == \"Sequential\":\n",
    "            hints.append(\"Use numbered step-by-step structure.\")\n",
    "        else:\n",
    "            hints.append(\"Start with a big-picture overview.\")\n",
    "        if labels[\"perception\"] == \"Sensing\":\n",
    "            hints.append(\"Include concrete real-world examples.\")\n",
    "        else:\n",
    "            hints.append(\"Include theories and conceptual connections.\")\n",
    "\n",
    "        return (\n",
    "            f\"You are EduGemma, a personalized AI tutor for {subject}.\\n\\n\"\n",
    "            f\"LEARNER PROFILE:\\n\"\n",
    "            f\"- Processing: {labels['processing']}\\n\"\n",
    "            f\"- Perception: {labels['perception']}\\n\"\n",
    "            f\"- Input: {labels['input']}\\n\"\n",
    "            f\"- Understanding: {labels['understanding']}\\n\\n\"\n",
    "            f\"Top formats for this learner: {', '.join(p[0] for p in top3)}\\n\\n\"\n",
    "            + \"\\n\".join(hints)\n",
    "        )\n",
    "\n",
    "\n",
    "ILS_QUESTIONS = [\n",
    "    (\"I understand something better after I:\",\n",
    "     \"Try it out (Active)\", \"Think it through (Reflective)\", \"active_reflective\", -1, 1),\n",
    "    (\"When I am learning new material I prefer:\",\n",
    "     \"Diagrams, charts, and visuals (Visual)\", \"Written text and explanations (Verbal)\",\n",
    "     \"visual_verbal\", -1, 1),\n",
    "    (\"I learn best when content is:\",\n",
    "     \"Step-by-step from basics (Sequential)\", \"Big picture overview first (Global)\",\n",
    "     \"sequential_global\", -1, 1),\n",
    "    (\"I prefer examples that are:\",\n",
    "     \"Concrete and real-world (Sensing)\", \"Abstract and theoretical (Intuitive)\",\n",
    "     \"sensing_intuitive\", -1, 1),\n",
    "    (\"In a study group I am more likely to:\",\n",
    "     \"Jump in and contribute ideas (Active)\", \"Sit back and listen first (Reflective)\",\n",
    "     \"active_reflective\", -1, 1),\n",
    "    (\"When solving a problem I tend to:\",\n",
    "     \"Work through it one step at a time (Sequential)\", \"See the solution then trace back (Global)\",\n",
    "     \"sequential_global\", -1, 1),\n",
    "    (\"I remember things better from:\",\n",
    "     \"Pictures, diagrams, and demonstrations (Visual)\", \"Spoken or written explanations (Verbal)\",\n",
    "     \"visual_verbal\", -1, 1),\n",
    "    (\"I find it easier to learn:\",\n",
    "     \"Facts and procedures (Sensing)\", \"Concepts and theories (Intuitive)\",\n",
    "     \"sensing_intuitive\", -1, 1),\n",
    "]\n",
    "\n",
    "def compute_ils_from_answers(answers: Dict[str, int]) -> ILSProfile:\n",
    "    \"\"\"answers: {dimension: cumulative score}\"\"\"\n",
    "    return ILSProfile(\n",
    "        active_reflective = answers.get(\"active_reflective\", 0),\n",
    "        sensing_intuitive = answers.get(\"sensing_intuitive\", 0),\n",
    "        visual_verbal     = answers.get(\"visual_verbal\", 0),\n",
    "        sequential_global = answers.get(\"sequential_global\", 0),\n",
    "    )"
   ]
