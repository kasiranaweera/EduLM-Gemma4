    "| Hallucination Rate | {m['hallucination']['baseline']['overall_hallucination_rate']:.4f} | **{m['hallucination']['finetuned']['overall_hallucination_rate']:.4f}** | -{s['hallucination_reduction']:.4f} |\n",
    "| ILS Adaptation | {m['ils_adaptation']['baseline']['mean_ils_adaptation']:.4f} | **{m['ils_adaptation']['finetuned']['mean_ils_adaptation']:.4f}** | +{s['ils_adaptation_gain']:.4f} |\n",
