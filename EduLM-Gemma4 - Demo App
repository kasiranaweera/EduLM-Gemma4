    "\n",
    "    # ---- Tab 3: Evaluation Results ----\n",
    "    with gr.Tab(\"📊 Step 3 — Evaluation Results\"):\n",
    "        gr.Markdown(\"### EduLM-Gemma4 vs Baseline (gemma-4-e4b-it, no fine-tuning)\")\n",
    "\n",
    "        eval_path = \"/kaggle/working/eval/evaluation_report.json\"\n",
