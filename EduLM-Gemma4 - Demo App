    "    for dim, label in labels.items():\n",
    "        icon = icons.get(label,\"\")\n",
    "        md += f\"| {dim.title()} | {icon} **{label}** | {descs[label]} |\\n\"\n",
    "\n",
    "    md += f\"\\n**Top content formats:** {', '.join(p[0] for p in top3)}\"\n",
    "    return md\n",
    "\n",
