",\n        \"Sensing\":\"Prefers facts and examples\",\n        \"Intuitive\":\"Prefers theories and concepts\",\n        \"Sequential\":\"Step-by-step structure\",\n        \"Global\":\"Big picture first\",\n    }\n    for dim, label in labels.items():\n        icon = icons.get(label,\"\")\n        md += f\"| {dim.title()} | {icon} **{label}** | {descs[label]} |\\n\"\n\n    md += f\"\\n**Top content formats:** {', '.join(p[0] for p in top3)}\"\n    return md\n\n\n# BUILD GRADIO UI\nSUBJECTS = [\"mathematics\", \"science\", \"technology\"]\n\nwith gr.Blocks(\n    title  = \"EduLM-Gemma4 — Personalized AI Tutor\",\n    theme  = gr.themes.Soft(primary_hue=\"blue\", secondary_hue=\"teal\"),\n    css    = \"\"\"\n        .highlight { background: #1a1d2e; border-radius: 8px; padding: 12px; }\n        .profile-box { border: 1px solid #4C9BE8; border-radius: 8px; padding: 12px; }\n    \"\"\"\n) as demo:\n\n    # ---- Header ----\n    gr.Markdown(\"\"\"\n    # 🎓 EduLM-Gemma4 — Personalized AI Education\n    **Gemma 4 × ILS Learning Styles | Kaggle Gemma 4 Good Hackathon**\n    *Adapts content format (charts, diagrams, notes, exercises) to YOUR learning style*\n    ---\n    \"\"\")\n\n    # ---- Tab 1: ILS Assessment ----\n    with gr.Tab(\"📋 Step 1 — Discover Your Learning Style\"):\n        gr.Markdown(\"\"\"\n        ### Answer 8 quick questions to identify your Felder-Silverman ILS profile\n        This takes ~1 minute and personalizes ALL content generated for you.\n        \"\"\")\n\n        ils_state   = gr.State({})\n        q_radios    = []\n\n        with gr.Column():\n            for i, (question, opt_a, opt_b, _, _, _) in enumerate(ILS_QUESTIONS):\n                gr.Markdown(f\"**Q{i+1}. {question}**\")\n                r = gr.Radio(\n                    choices = [(\"a)  \" + opt_a, \"a\"),\n                               (\"b)  \" + opt_b, \"b\")],\n                    label   = \"\",\n                    value   = \"a\",\n                )\n                q_radios.append(r)\n\n        with gr.Row():\n            assess_btn  = gr.Button(\"🔍 Identify My Learning Style\",\n                                    variant=\"primary\", size=\"lg\")\n            reset_btn   = gr.Button(\"🔄 Reset\", size=\"lg\")\n\n        profile_display = gr.Markdown(label=\"Your ILS Profile\")\n        profile_state   = gr.State(None)\n\n        def run_assessment(*answers):\n            reset_ils()\n            for i, ans in enumerate(answers):\n                answer_question(i, ans)\n            profile = get_profile()\n            return profile_to_markdown(profile), profile\n\n        assess_btn.click(\n            run_assessment,\n            inputs  = q_radios,\n            outputs = [profile_display, profile_state]\n        )\n        reset_btn.click(\n            lambda: (\"\", None),\n            outputs = [profile_display, profile_state]\n        )\n\n    # ---- Tab 2: Learn ----\n    with gr.Tab(\"💬 Step 2 — Ask EduLM-Gemma4\"):\n        gr.Markdown(\"### Ask any question — content adapts to your learning style\")\n\n        with gr.Row():\n            subject_dd = gr.Dropdown(\n                choices = SUBJECTS, value = \"mathematics\",\n                label   = \"Subject\", scale=1\n            )\n            question_tb = gr.Textbox(\n                placeholder = \"e.g. Explain quadratic equations with examples...\",\n                label       = \"Your Question\",\n                lines       = 2, scale=3\n            )\n\n        generate_btn = gr.Button(\"🚀 Generate Personalized Content\",\n                                 variant=\"primary\", size=\"lg\")\n\n        with gr.Row():\n            text_out = gr.Markdown(label=\"📚 Content\")\n\n        with gr.Row():\n            gallery_out = gr.Gallery(\n                label   = \"📊 Charts & Infographics\",\n                columns = 2, height=380\n            )\n\n        exercises_out = gr.Markdown(label=\"💪 Practice Exercises\")\n        status_out    = gr.Markdown()\n\n        def run_generate(question, subject, profile):\n            # Fix: guard against None values from empty Gradio inputs\n            question = question or \"\"\n            subject  = subject  or \"mathematics\"\n\n            if not profile:\n                return (\n                    \"⚠️ **Please complete the ILS assessment in Step 1 first!**\",\n                    [], \"\", \"\"\n                )\n            if not question.strip():\n                return \"⚠️ Please enter a question.\", [], \"\", \"\"\n\n            raw_response = generate(question, subject, profile)\n            clean, images, exercises, notes = _renderer.parse_and_render(raw_response)\n\n            exercises_md = \"\"\n            if exercises:\n                exercises_md = \"## 💪 Practice Problems\\n\\n\"\n                badges = {\"easy\":\"🟢\",\"medium\":\"🟡\",\"hard\":\"🔴\"}\n                for ex in exercises:\n                    b = badges.get(ex[\"difficulty\"], \"⚪\")\n                    exercises_md += f\"{b} **{ex['difficulty'].title()}:** {ex['question']}\\n\\n\"\n\n            labels = profile.get_labels()\n            style  = f\"{labels['input']} · {labels['processing']}\"\n            status = f\"*Generated for: **{style}** learner | Subject: {subject}*\"\n\n            return clean, images, exercises_md, status\n\n        generate_btn.click(\n            run_generate,\n            inputs  = [question_tb, subject_dd, profile_state],\n            outputs = [text_out, gallery_out, exercises_out, status_out]\n        )\n\n        # ---- Quick example buttons ----\n        gr.Markdown(\"### 🎯 Try These Examples\")\n        with gr.Row():\n            examples = [\n                (\"📐 Quadratic Equations\", \"Explain quadratic equations with worked examples\", \"mathematics\"),\n                (\"🔬 Photosynthesis\",       \"Explain photosynthesis step by step\",              \"science\"),\n                (\"💻 Neural Networks\",     \"How does a neural network learn?\",                 \"technology\"),\n                (\"📊 Probability\",         \"Explain probability with real world examples\",     \"mathematics\"),\n            ]\n            for label, q, subj in examples:\n                btn = gr.Button(label, size=\"sm\")\n                btn.click(lambda q=q, s=subj: (q, s),\n                          outputs=[question_tb, subject_dd])\n\n    # ---- Tab 3: Evaluation Results ----\n    with gr.Tab(\"📊 Step 3 — Evaluation Results\"):\n        gr.Markdown(\"### EduLM-Gemma4 vs Baseline (gemma-4-e4b-it, no fine-tuning)\")\n\n        eval_path = \"/kaggle/working/eval/evaluation_report.json\"\n        if os.path.exists(eval_path):\n            with open(eval_path) as f:\n                eval_data = json_lib.load(f)\n            m = eval_data[\"metrics\"]\n            s = eval_data[\"summary\"]\n\n            gr.Markdown(f\"\"\"\n| Metric | Baseline | **EduGemma4** | Improvement |\n|--------|----------|--------------|-------------|\n| ROUGE-1 | {m['rouge']['baseline']['rouge1']:.4f} | **{m['rouge']['finetuned']['rouge1']:.4f}** | +{s['rouge1_improvement']:.4f} |\n| ROUGE-2 | {m['rouge']['baseline']['rouge2']:.4f} | **{m['rouge']['finetuned']['rouge2']:.4f}** | +{m['rouge']['finetuned']['rouge2']-m['rouge']['baseline']['rouge2']:.4f} |\n| BERTScore F1 | {m['bertscore']['baseline']['f1']:.4f} | **{m['bertscore']['finetuned']['f1']:.4f}** | +{s['bertscore_f1_improvement']:.4f} |\n| Hallucination Rate | {m['hallucination']['baseline']['overall_hallucination_rate']:.4f} | **{m['hallucination']['finetuned']['overall_hallucination_rate']:.4f}** | -{s['hallucination_reduction']:.4f} |\n| ILS Adaptation | {m['ils_adaptation']['baseline']['mean_ils_adaptation']:.4f} | **{m['ils_adaptation']['finetuned']['mean_ils_adaptation']:.4f}** | +{s['ils_adaptation_gain']:.4f} |\n\"\"\")\n        else:\n            gr.Markdown(\"*Run Notebook 3 first to generate evaluation results.*\")\n\n        if os.path.exists(\"/kaggle/working/eval/evaluation_dashboard.png\"):\n            gr.Image(\"/kaggle/working/eval/evaluation_dashboard.png\",\n                     label=\"Evaluation Dashboard\")\n\n        if os.path.exists(\"/kaggle/working/logs/loss_curve.png\"):\n            gr.Image(\"/kaggle/working/logs/loss_curve.png\",\n                     label=\"Training Loss Curve\")\n\n    # ---- Tab 4: About ----\n    with gr.Tab(\"ℹ️ About\"):\n        gr.Markdown(\"\"\"\n        ## About EduLM-Gemma4\n\n        Built for the **[Kaggle × Google DeepMind Gemma 4 Good Hackathon](https://www.kaggle.com/competitions/gemma-4-good-hackathon)** — Education Track.\n\n        ### System Architecture\n        | Layer | Component |\n        |-------|-----------|\n        | 1. ILS Engine | Felder-Silverman 4-dimension learning style model |\n        | 2. Dataset | ILS-personalized JSONL, 80/10/10 split, diversity metrics |\n        | 3. Fine-tuning | QLoRA r=16 on gemma-4-e4b-it via Unsloth |\n        | 4. Content Engine | Charts (Matplotlib) · Diagrams · Infographics (PIL) |\n        | 5. Demo | Gradio app with full ILS assessment pipeline |\n\n        ### ILS Dimensions (Felder-Silverman)\n        - **Active ↔ Reflective** — how you process information\n        - **Sensing ↔ Intuitive** — what kind of information you prefer\n        - **Visual ↔ Verbal** — how you receive information\n        - **Sequential ↔ Global** — how you organize information\n\n        ### Subjects\n        Mathematics · Science · Technology\n\n        ### Impact\n        - Personalized tutoring for students without access to private tutors\n        - Works offline (GGUF export via Unsloth)\n        - Deployable on low-cost hardware ($35 Raspberry Pi)\n        \"\"\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-19T21:14:37.176940Z","iopub.execute_input":"2026-05-19T21:14:37.177489Z","iopub.status.idle":"2026-05-19T21:14:37.436216Z","shell.execute_reply.started":"2026-05-19T21:14:37.177438Z","shell.execute_reply":"2026-0