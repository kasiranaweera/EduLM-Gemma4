    "# STEP 6: Gradio App\n",
    "import gradio as gr\n",
    "\n",
    "# Track ILS scores across questions\n",
    "_ils_scores = {\"active_reflective\":0, \"sensing_intuitive\":0,\n",
    "               \"visual_verbal\":0,     \"sequential_global\":0}\n",
    "\n",
    "def reset_ils():\n",
    "    global _ils_scores\n",
    "    _ils_scores = {k:0 for k in _ils_scores}\n",
    "\n",
    "def answer_question(q_idx: int, choice: str):\n",
    "    \"\"\"choice: 'a' or 'b'\"\"\"\n",
