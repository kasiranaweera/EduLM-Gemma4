    "from io import BytesIO\n",
    "import base64\n",
    "from typing import List, Optional, Tuple, Any\n",
    "\n",
    "class ContentRenderer:\n",
    "    PALETTE = [\"#4C9BE8\",\"#F4A261\",\"#2A9D8F\",\"#E76F51\",\"#8338EC\",\"#06D6A0\"]\n",
    "\n",
    "    def _dark_fig(self, w=10, h=5.5):\n",
    "        fig, ax = plt.subplots(figsize=(w, h))\n",
    "        fig.patch.set_facecolor('#0F1117')\n",
    "        ax.set_facecolor('#1A1D2E')\n",
    "        ax.tick_params(colors='#CCC', labelsize=10)\n",
    "        for sp in ['top','right']:   ax.spines[sp].set_visible(False)\n",
    "        for sp in ['bottom','left']: ax.spines[sp].set_color('#444')\n",
    "        return fig, ax\n",
    "\n",
    "    def render_chart(self, ctype: str, data: dict) -> Optional[Image.Image]:\n",
    "        try:\n",
    "            fig, ax = self._dark_fig()\n",
    "            ct     = ctype.strip().lower()\n",
    "            labels = data.get(\"labels\", [])\n",
    "            values = data.get(\"values\", [])\n",
    "            colors = self.PALETTE[:len(labels)]\n",
    "\n",
    "            if ct == \"bar\":\n",
    "                bars = ax.bar(labels, values, color=colors,\n",
    "                              edgecolor='white', linewidth=0.4, alpha=0.88)\n",
    "                ax.bar_label(bars, fmt='%.1f', color='white',\n",
    "                             fontsize=9, padding=3)\n",
    "            elif ct == \"line\":\n",
    "                series = data.get(\"series\", [{\"values\": values, \"name\": \"\"}])\n",
    "                x = list(range(len(labels)))\n",
    "                for i, s in enumerate(series):\n",
    "                    c = self.PALETTE[i % len(self.PALETTE)]\n",
    "                    ax.plot(x, s[\"values\"], marker='o', lw=2.5, color=c,\n",
    "                            label=s.get(\"name\",\"\"), markersize=5,\n",
    "                            markerfacecolor='white', markeredgecolor=c)\n",
    "                    ax.fill_between(x, s[\"values\"], alpha=0.1, color=c)\n",
    "                ax.set_xticks(x)\n",
    "                ax.set_xticklabels(labels, rotation=15, color='white')\n",
    "                if len(series) > 1:\n",
    "                    ax.legend(facecolor='#1A1D2E', labelcolor='white')\n",
    "            elif ct == \"pie\":\n",
    "                ax.pie(values, labels=labels, autopct='%1.1f%%',\n",
    "                       colors=colors, explode=[0.03]*len(labels),\n",
    "                       startangle=90,\n",
    "                       textprops={'color':'white'}, pctdistance=0.82)\n",
    "            elif ct == \"scatter\":\n",
    "                pts = data.get(\"points\", list(zip(range(len(values)), values)))\n",
    "                ax.scatter([p[0] for p in pts], [p[1] for p in pts],\n",
    "                           c=colors[0], s=80, alpha=0.85, edgecolors='white')\n",
    "\n",
    "            if t := data.get(\"title\"):\n",
    "                ax.set_title(t, color='white', fontsize=13,\n",
    "                             fontweight='bold', pad=10)\n",
    "            if y := data.get(\"ylabel\"):\n",
    "                ax.set_ylabel(y, color='#AAA')\n",
    "\n",
    "            plt.tight_layout()\n",
    "            buf = BytesIO()\n",
    "            fig.savefig(buf, format='png', bbox_inches='tight',\n",
    "                        facecolor='#0F1117', dpi=130)\n",
    "            plt.close(fig)\n",
    "            buf.seek(0)\n",
    "            return Image.open(buf).copy()\n",
    "        except Exception as e:\n",
    "            print(f\"Chart error: {e}\")\n",
    "            return None\n",
    "\n",
    "    def render_infographic(self, title: str, data: dict) -> Optional[Image.Image]:\n",
    "        try:\n",
    "            items = (data.get(\"concepts\") or data.get(\"laws\") or\n",
    "                     data.get(\"items\") or [])\n",
    "            if not items: return None\n",
    "            W, IH = 900, 90\n",
    "            H = 70 + len(items) * IH + 20\n",
    "            img  = Image.new(\"RGB\", (W, H), (15, 17, 23))\n",
    "            draw = ImageDraw.Draw(img)\n",
    "            try:\n",
    "                fB = ImageFont.truetype(\n",
    "                    \"/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf\", 20)\n",
    "                fR = ImageFont.truetype(\n",
    "                    \"/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf\", 13)\n",
    "            except:\n",
    "                fB = fR = ImageFont.load_default()\n",
    "\n",
    "            draw.rectangle([0,0,W,58], fill=(26,29,46))\n",
    "            draw.text((20,16), title, fill=(255,255,255), font=fB)\n",
    "\n",
    "            COLS = [\"#4C9BE8\",\"#F4A261\",\"#2A9D8F\",\"#E76F51\",\"#8338EC\"]\n",
    "            for i, item in enumerate(items):\n",
    "                y  = 70 + i * IH\n",
    "                ac = COLS[i % len(COLS)]\n",
    "                r,g,b = int(ac[1:3],16), int(ac[3:5],16), int(ac[5:7],16)\n",
    "                draw.rectangle([14, y, W-14, y+IH-6], fill=(26,29,46),\n",
    "                               outline=ac, width=1)\n",
    "                draw.rectangle([14, y, 26,   y+IH-6], fill=(r,g,b))\n",
    "                num  = str(item.get(\"num\", i+1))\n",
    "                name = item.get(\"name\",\"\")\n",
    "                desc = item.get(\"desc\", item.get(\"formula\",\n",
    "                               item.get(\"example\",\"\")))[:100]\n",
    "                draw.text((38, y+10), num,  fill=(r,g,b),          font=fB)\n",
    "                draw.text((72, y+10), name, fill=(255,255,255),     font=fB)\n",
    "                draw.text((72, y+38), desc, fill=(180,180,200),     font=fR)\n",
    "            return img\n",
    "        except Exception as e:\n",
    "            print(f\"Infographic error: {e}\")\n",
    "            return None\n",
    "\n",
    "    CHART_RE    = re.compile(r'\\[CHART:\\s*([^\\|]+)\\s*\\|\\s*(\\{[^\\]]+\\})\\]', re.DOTALL)\n",
    "    DIAGRAM_RE  = re.compile(r'\\[DIAGRAM:\\s*[^\\]]+\\]',                       re.DOTALL)\n",
    "    INFOG_RE    = re.compile(r'\\[INFOGRAPHIC:\\s*([^\\|]+)\\s*\\|\\s*(\\{[^\\]]+\\})\\]', re.DOTALL)\n",
    "    EXERCISE_RE = re.compile(r'\\[EXERCISE:\\s*([^\\|]+)\\s*\\|\\s*(.*?)\\]',       re.DOTALL)\n",
    "    NOTE_RE     = re.compile(r'\\[NOTE:\\s*(.*?)\\]',                            re.DOTALL)\n",
    "\n",
    "    def parse_and_render(self, text: str):\n",
    "        images, exercises, notes = [], [], []\n",
    "\n",
    "        for m in self.CHART_RE.finditer(text):\n",
    "            try:\n",
    "                img = self.render_chart(m.group(1),\n",
    "                                        json_lib.loads(m.group(2).strip()))\n",
    "                if img: images.append(img)\n",
    "            except: pass\n",
    "\n",
    "        for m in self.INFOG_RE.finditer(text):\n",
    "            try:\n",
    "                img = self.render_infographic(m.group(1).strip(),\n",
    "                                              json_lib.loads(m.group(2).strip()))\n",
    "                if img: images.append(img)\n",
    "            except: pass\n",
    "\n",
    "        for m in self.EXERCISE_RE.finditer(text):\n",
    "            exercises.append({\"difficulty\": m.group(1).strip(),\n",
    "                              \"question\":   m.group(2).strip()})\n",
    "        for m in self.NOTE_RE.finditer(text):\n",
    "            notes.append(m.group(1).strip())\n",
    "\n",
    "        clean = self.CHART_RE.sub(\"📊 *[Chart rendered below]*\", text)\n",
    "        clean = self.DIAGRAM_RE.sub(\"📐 *[Diagram]*\", clean)\n",
    "        clean = self.INFOG_RE.sub(\"🖼️ *[Infographic rendered below]*\", clean)\n",
    "        clean = self.EXERCISE_RE.sub(\n",
    "            lambda m: f\"\\n\\n> 💪 **Exercise ({m.group(1)}):** {m.group(2)}\\n\", clean)\n",
    "        clean = self.NOTE_RE.sub(\n",
    "            lambda m: f\"\\n\\n> 📌 **Key Concept:** {m.group(1)}\\n\", clean)\n",
    "\n",
    "        return clean.strip(), images, exercises, notes"
   ]
  },
