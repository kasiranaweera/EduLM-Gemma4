    "print(\"⏳ Loading base model (BASELINE)...\")\n",
    "base_model, tokenizer = FastLanguageModel.from_pretrained(\n",
    "    model_name    = BASE_MODEL,\n",
    "    max_seq_length = 2048,\n",
    "    dtype          = None,\n",
