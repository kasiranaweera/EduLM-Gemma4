    "            temperature        = 0.7,\n",
    "            do_sample          = True,\n",
    "            top_p              = 0.92,\n",
    "            repetition_penalty = 1.1,\n",
    "        )\n",
    "    decoded = tokenizer.decode(out[0], skip_special_tokens=True)\n",
    "    return decoded.split(\"model\\n\")[-1].strip()"
