    "# STEP 9: Hallucination Rate\n",
    "# Custom hallucination proxy: checks if educational content tags\n",
    "# are well-formed and if factual markers are consistent.\n",
    " \n",
    "print(\"\\n📊 HALLUCINATION RATE\")\n",
    "print(\"=\"*55)\n",
    "import re\n",
    " \n",
    "def compute_hallucination_rate(preds: list, samples: list) -> dict:\n",
    "    \"\"\"\n",
    "    Proxy metrics for hallucination in educational context:\n",
    "    1. Malformed tag rate (model invents broken [CHART] structures)\n",
    "    2. Subject drift (model answers about wrong subject)\n",
    "    3. Tag-content mismatch (e.g. claims chart exists but gives no data)\n",
    "    \"\"\"\n",
    "    malformed_tags  = 0\n",
    "    subject_drifts  = 0\n",
    "    empty_tag_bodies= 0\n",
    "    total = len(preds)\n",
    " \n",
    "    chart_pattern   = re.compile(r'\\[CHART:\\s*\\w+\\s*\\|\\s*(\\{[^]]+\\})\\]')\n",
    "    diagram_pattern = re.compile(r'\\[DIAGRAM:\\s*[^\\|]+\\s*\\|\\s*(graph\\s+\\w+[^\\]]+)\\]')\n",
    " \n",
    "    for pred, sample in zip(preds, samples):\n",
    "        subject = sample[\"metadata\"][\"subject\"]\n",
    " \n",
    "        # 1. Malformed chart JSON\n",
    "        for m in re.finditer(r'\\[CHART:[^\\]]*\\]', pred):\n",
    "            try:\n",
    "                cm = chart_pattern.match(m.group())\n",
    "                if cm:\n",
    "                    json.loads(cm.group(1))\n",
    "                else:\n",
    "                    malformed_tags += 1\n",
    "            except:\n",
    "                malformed_tags += 1\n",
    " \n",
    "        # 2. Subject drift — check if response mentions a different subject\n",
    "        other_subjects = [s for s in [\"mathematics\",\"science\",\"technology\"]\n",
    "                          if s != subject]\n",
    "        pred_lower = pred.lower()\n",
    "        if any(f\"this is a {s}\" in pred_lower or\n",
    "               f\"in {s} class\" in pred_lower\n",
    "               for s in other_subjects):\n",
    "            subject_drifts += 1\n",
    " \n",
    "        # 3. Empty tag bodies\n",
    "        if \"[CHART:\" in pred and \"values\" not in pred:\n",
    "            empty_tag_bodies += 1\n",
    "        if \"[DIAGRAM:\" in pred and \"graph\" not in pred.lower():\n",
    "            empty_tag_bodies += 1\n",
    " \n",
    "    return {\n",
    "        \"malformed_tag_rate\":   round(malformed_tags   / total, 4),\n",
    "        \"subject_drift_rate\":   round(subject_drifts   / total, 4),\n",
    "        \"empty_tag_body_rate\":  round(empty_tag_bodies  / total, 4),\n",
    "        \"overall_hallucination_rate\": round(\n",
    "            (malformed_tags + subject_drifts + empty_tag_bodies) / (total * 3), 4\n",
    "        ),\n",
    "        \"counts\": {\n",
    "            \"malformed_tags\": malformed_tags,\n",
    "            \"subject_drifts\": subject_drifts,\n",
    "            \"empty_tag_bodies\": empty_tag_bodies,\n",
    "            \"total_samples\": total,\n",
    "        }\n",
    "    }\n",
    " \n",
    "base_hall = compute_hallucination_rate(base_preds, eval_samples)\n",
    "ft_hall   = compute_hallucination_rate(ft_preds,   eval_samples)\n",
    " \n",
    "print(f\"\\n{'Metric':<30} {'Gemma4':>10} {'EduLM-Gemma4':>12} {'Better?':>8}\")\n",
    "print(\"-\"*65)\n",
    "for metric in [\"malformed_tag_rate\",\"subject_drift_rate\",\n",
    "               \"empty_tag_body_rate\",\"overall_hallucination_rate\"]:\n",
    "    base_v = base_hall[metric]\n",
    "    ft_v   = ft_hall[metric]\n",
    "    # Lower is better for hallucination\n",
    "    better = \"✅ Yes\" if ft_v <= base_v else \"❌ No\"\n",
    "    print(f\"{metric:<30} {base_v:>10.4f} {ft_v:>12.4f} {better:>8}\")"
   ]
