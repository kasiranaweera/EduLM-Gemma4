    "    return {\n",
    "        \"rouge1\": round(np.mean(r1), 4),\n",
    "        \"rouge2\": round(np.mean(r2), 4),\n",
    "        \"rougeL\": round(np.mean(rL), 4),\n",
    "    }\n",
