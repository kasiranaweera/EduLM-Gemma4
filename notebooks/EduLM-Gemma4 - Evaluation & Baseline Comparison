    "# STEP 10: ILS Adaptation Score (custom metric)\n",
    "# Measures how well the model adapts content format to learner style\n",
    " \n",
    "print(\"\\n📊 ILS ADAPTATION SCORE (Custom Metric)\")\n",
    "print(\"=\"*55)\n",
    " \n",
    "def ils_adaptation_score(preds: list, samples: list) -> dict:\n",
    "    \"\"\"\n",
    "    For each sample, checks if the response format matches\n",
    "    the ILS profile. E.g. Visual learner → expects [CHART]/[DIAGRAM]\n",
    "    \"\"\"\n",
    "    scores = []\n",
    "    for pred, sample in zip(preds, samples):\n",
    "        meta     = sample[\"metadata\"]\n",
    "        expected = []\n",
    "        if meta[\"ils_input\"] == \"Visual\":\n",
    "            expected.extend([\"[CHART:\", \"[DIAGRAM:\"])\n",
    "        if meta[\"ils_processing\"] == \"Active\":\n",
    "            expected.append(\"[EXERCISE:\")\n",
    "        if meta[\"ils_understanding\"] == \"Sequential\":\n",
    "            # Expect numbered steps\n",
    "            expected.append(\"1.\")\n",
    "        if meta[\"ils_perception\"] == \"Sensing\":\n",
    "            # Expect examples\n",
    "            expected.append(\"example\")\n",
    " \n",
    "        if not expected:\n",
    "            scores.append(1.0)\n",
    "            continue\n",
    " \n",
    "        matched = sum(1 for e in expected if e.lower() in pred.lower())\n",
    "        scores.append(matched / len(expected))\n",
    " \n",
    "    return {\n",
    "        \"mean_ils_adaptation\": round(np.mean(scores), 4),\n",
    "        \"pct_fully_adapted\":   round(sum(1 for s in scores if s == 1.0) / len(scores), 4),\n",
    "        \"pct_partially_adapted\": round(sum(1 for s in scores if 0 < s < 1.0) / len(scores), 4),\n",
    "        \"pct_not_adapted\":     round(sum(1 for s in scores if s == 0.0) / len(scores), 4),\n",
    "    }\n",
    " \n",
    "base_ils = ils_adaptation_score(base_preds, eval_samples)\n",
    "ft_ils   = ils_adaptation_score(ft_preds,   eval_samples)\n",
    " \n",
    "print(f\"\\n{'Metric':<28} {'Baseline':>10} {'EduGemma4':>12}\")\n",
    "print(\"-\"*52)\n",
    "for metric in [\"mean_ils_adaptation\",\"pct_fully_adapted\",\n",
    "               \"pct_partially_adapted\",\"pct_not_adapted\"]:\n",
    "    better = \"✅\" if ft_ils[metric] >= base_ils[metric] else \"❌\"\n",
    "    if metric == \"pct_not_adapted\":\n",
    "        better = \"✅\" if ft_ils[metric] <= base_ils[metric] else \"❌\"\n",
    "    print(f\"{better} {metric:<26} {base_ils[metric]:>10.4f} {ft_ils[metric]:>12.4f}\")"
   ]
