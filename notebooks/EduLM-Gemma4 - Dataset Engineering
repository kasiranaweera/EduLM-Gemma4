{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"competition","sourceId":134561,"databundleVersionId":16421787}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"<div align=\"center\">\n\n##### ===================================================================================================================================================\n#  EduLM-Gemma4 — Notebook 1: Dataset Engineering & ILS Builder\n##  Kaggle Gemma 4 Good Hackathon | Education Track\n##### ===================================================================================================================================================\n\n\n</div>\n\n<br>\n\n- **Pipeline**: NB1 (Dataset) → NB2 (Fine-tune) → NB3 (Eval) → NB4 (Demo App)\n- **Settings**:\n    * GPU        : Not needed\n    * Internet   : ON (for Kaggle dataset upload)\n    * Visibility : Private OK\n    * Output     : Kaggle Dataset \"edulmgemma4-data\"\n","metadata":{}},{"cell_type":"code","source":"# STEP 1: Install packages\n# No GPU required. Pure Python dataset engineering.\n \n# !pip install -q datasets==3.1.0\n# print(\"✅ Packages ready\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:32.836195Z","iopub.execute_input":"2026-05-12T10:00:32.837191Z","iopub.status.idle":"2026-05-12T10:00:32.844200Z","shell.execute_reply.started":"2026-05-12T10:00:32.837149Z","shell.execute_reply":"2026-05-12T10:00:32.842759Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 2: Imports\n \nimport json\nimport random\nimport os\nimport shutil\nimport subprocess\nfrom dataclasses import dataclass\nfrom typing import Dict, List\nfrom collections import Counter\n \nrandom.seed(42)\nprint(\"✅ Imports complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:32.847337Z","iopub.execute_input":"2026-05-12T10:00:32.848120Z","iopub.status.idle":"2026-05-12T10:00:32.887242Z","shell.execute_reply.started":"2026-05-12T10:00:32.848084Z","shell.execute_reply":"2026-05-12T10:00:32.884839Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 3: ILS Model (Felder-Silverman)\n \n@dataclass\nclass ILSProfile:\n    \"\"\"\n    Felder-Silverman Index of Learning Styles — 4 dimensions.\n    Score range: -11 to +11 per dimension.\n      active_reflective : negative=Active,     positive=Reflective\n      sensing_intuitive : negative=Sensing,    positive=Intuitive\n      visual_verbal     : negative=Visual,     positive=Verbal\n      sequential_global : negative=Sequential, positive=Global\n    \"\"\"\n    active_reflective: int\n    sensing_intuitive: int\n    visual_verbal: int\n    sequential_global: int\n \n    def label(self, score: int, neg: str, pos: str) -> str:\n        if abs(score) <= 3:\n            return f\"Balanced({neg}/{pos})\"\n        return pos if score > 0 else neg\n \n    def get_labels(self) -> Dict[str, str]:\n        return {\n            \"processing\":    self.label(self.active_reflective, \"Active\", \"Reflective\"),\n            \"perception\":    self.label(self.sensing_intuitive, \"Sensing\", \"Intuitive\"),\n            \"input\":         self.label(self.visual_verbal, \"Visual\", \"Verbal\"),\n            \"understanding\": self.label(self.sequential_global, \"Sequential\", \"Global\"),\n        }\n \n    def get_style_key(self) -> str:\n        \"\"\"Return short style key for dataset tagging.\"\"\"\n        labels = self.get_labels()\n        p = labels[\"processing\"][0]\n        q = labels[\"perception\"][0]\n        input_char = \"Vi\" if \"Visual\" in labels[\"input\"] else (\"Ve\" if \"Verbal\" in labels[\"input\"] else \"B\")\n        u = labels[\"understanding\"][0]\n        return f\"{p}{q}{input_char}{u}\"\n \n    def content_weights(self) -> Dict[str, float]:\n        \"\"\"Maps ILS scores to content-type preference weights (0.0–1.0).\"\"\"\n        vis    = max(0, -self.visual_verbal)     / 11.0\n        act    = max(0, -self.active_reflective) / 11.0\n        ref    = max(0,  self.active_reflective) / 11.0\n        sens   = max(0, -self.sensing_intuitive) / 11.0\n        intuit = max(0,  self.sensing_intuitive) / 11.0\n        seq    = max(0, -self.sequential_global) / 11.0\n        glob   = max(0,  self.sequential_global) / 11.0\n        return {\n            \"diagrams\":     round(0.3 + vis  * 0.7, 2),\n            \"charts\":       round(0.3 + vis  * 0.6, 2),\n            \"infographics\": round(0.2 + vis  * 0.5, 2),\n            \"qa\":           round(0.3 + act  * 0.7, 2),\n            \"exercises\":    round(0.2 + act  * 0.6, 2),\n            \"reflection\":   round(0.2 + ref  * 0.7, 2),\n            \"notes\":        round(0.4 + sens * 0.6, 2),\n            \"examples\":     round(0.3 + sens * 0.5, 2),\n            \"theory\":       round(0.2 + intuit * 0.7, 2),\n            \"step_by_step\": round(0.3 + seq  * 0.7, 2),\n            \"summary\":      round(0.2 + glob * 0.7, 2),\n        }\n \nprint(\"✅ ILSProfile class defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:32.889310Z","iopub.execute_input":"2026-05-12T10:00:32.889985Z","iopub.status.idle":"2026-05-12T10:00:32.933001Z","shell.execute_reply.started":"2026-05-12T10:00:32.889941Z","shell.execute_reply":"2026-05-12T10:00:32.931225Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 4: 16 ILS Profile Definitions\n \nILS_PROFILES = [\n    # Strong preferences\n    ILSProfile(-9, -7, -9, -7),   # Strong Active-Sensing-Visual-Sequential\n    ILSProfile(+9, +7, +7, +7),   # Strong Reflective-Intuitive-Verbal-Global\n    ILSProfile(-9, -7, -9, +7),   # Strong Active-Sensing-Visual-Global\n    ILSProfile(+9, +7, +7, -7),   # Strong Reflective-Intuitive-Verbal-Sequential\n    ILSProfile(-9, +7, -9, -7),   # Strong Active-Intuitive-Visual-Sequential\n    ILSProfile(+9, -7, +7, +7),   # Strong Reflective-Sensing-Verbal-Global\n    ILSProfile(-9, +7, -9, +7),   # Strong Active-Intuitive-Visual-Global\n    ILSProfile(+9, -7, +7, -7),   # Strong Reflective-Sensing-Verbal-Sequential\n    # Moderate preferences\n    ILSProfile(-5, -5, -7, -5),   # Moderate Active-Sensing-Visual-Sequential\n    ILSProfile(+5, +5, +5, +5),   # Moderate Reflective-Intuitive-Verbal-Global\n    ILSProfile(-5, -5, -7, +5),   # Moderate Active-Sensing-Visual-Global\n    ILSProfile(+5, +5, +5, -5),   # Moderate Reflective-Intuitive-Verbal-Sequential\n    ILSProfile(-7, +5, -5, -7),   # Moderate Active-Intuitive-Visual-Sequential\n    ILSProfile(+7, -5, +7, +5),   # Moderate Reflective-Sensing-Verbal-Global\n    ILSProfile(-3, -7, -9, +3),   # Near-Balanced Active, Strong Visual, Sensing, Slight Global\n    ILSProfile(+3, +7, +3, -3),   # Near-Balanced Reflective, Verbal, Intuitive, Slight Sequential\n]\n \nprint(f\"✅ {len(ILS_PROFILES)} ILS profiles defined\")\nfor p in ILS_PROFILES[:3]:\n    print(f\"  {p.get_style_key()} → {p.get_labels()}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:32.936125Z","iopub.execute_input":"2026-05-12T10:00:32.936468Z","iopub.status.idle":"2026-05-12T10:00:32.997133Z","shell.execute_reply.started":"2026-05-12T10:00:32.936437Z","shell.execute_reply":"2026-05-12T10:00:32.995772Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 5: System Prompt Builder\n \ndef build_system_prompt(profile: ILSProfile, subject: str) -> str:\n    labels  = profile.get_labels()\n    weights = profile.content_weights()\n    top3    = sorted(weights.items(), key=lambda x: x[1], reverse=True)[:3]\n    pref_str = \", \".join(f[0] for f in top3)\n \n    if   \"Active\"     in labels[\"processing\"]:    proc_hint = \"Engage the learner with hands-on tasks, exercises, and apply-first activities.\"\n    elif \"Reflective\" in labels[\"processing\"]:    proc_hint = \"Allow time for analysis. Include reflection prompts and think-before-act exercises.\"\n    else:                                          proc_hint = \"Mix active exercises with reflective pauses.\"\n \n    if   \"Visual\"  in labels[\"input\"]: input_hint = \"Prioritize [DIAGRAM] and [CHART] blocks. Use visual analogies. Minimize dense text.\"\n    elif \"Verbal\"  in labels[\"input\"]: input_hint = \"Use clear written explanations, descriptions, and well-structured prose.\"\n    else:                               input_hint = \"Mix visual elements with written explanation equally.\"\n \n    if   \"Sequential\" in labels[\"understanding\"]: und_hint = \"Present step-by-step, building from Part 1 to Part N. No jumping ahead.\"\n    elif \"Global\"     in labels[\"understanding\"]: und_hint = \"Open with the big-picture overview and real-world context before details.\"\n    else:                                          und_hint = \"Briefly frame the big picture, then follow with structured steps.\"\n \n    if   \"Sensing\"   in labels[\"perception\"]: perc_hint = \"Use concrete facts, worked examples, and real-world applications throughout.\"\n    elif \"Intuitive\" in labels[\"perception\"]: perc_hint = \"Connect concepts to theories, patterns, and higher-level principles.\"\n    else:                                      perc_hint = \"Balance concrete examples with conceptual patterns.\"\n \n    return f\"\"\"You are EduLM, a personalized AI tutor for {subject} powered by Gemma 4.\n \nLEARNER PROFILE (Felder-Silverman ILS):\n- Processing:    {labels['processing']} → {proc_hint}\n- Perception:    {labels['perception']} → {perc_hint}\n- Input:         {labels['input']} → {input_hint}\n- Understanding: {labels['understanding']} → {und_hint}\n \nTOP CONTENT FORMATS FOR THIS LEARNER: {pref_str}\n \nCONTENT GENERATION TAGS (embed these inline in your response):\n[CHART: type | json_data]           → renders a chart (bar/line/pie/scatter)\n[DIAGRAM: title | mermaid_code]     → renders a Mermaid.js diagram\n[INFOGRAPHIC: title | json_data]    → renders an infographic card\n[EXERCISE: difficulty | question]   → interactive practice problem\n[NOTE: key_concept]                 → highlighted key concept callout box\n \nRESPONSE RULES:\n1. ALWAYS adapt format to match the learner's ILS profile above.\n2. Visual learner → lead with [DIAGRAM] or [CHART]; use tables and structured layouts.\n3. Verbal learner → use rich, clear prose; avoid overloading with diagrams.\n4. Active learner → include at least one [EXERCISE] block.\n5. Reflective learner → add a reflection or \"think about this\" closing prompt.\n6. Sequential learner → use numbered steps; never skip or reorder stages.\n7. Global learner → open with a real-world hook or big-picture overview paragraph.\n8. Sensing learner → ground everything in concrete facts and worked examples.\n9. Intuitive learner → connect to theory, patterns, and cross-domain analogies.\n10. Keep responses educational, accurate, encouraging, and focused on {subject}.\"\"\"\n \nprint(\"✅ build_system_prompt() defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:32.998844Z","iopub.execute_input":"2026-05-12T10:00:32.999243Z","iopub.status.idle":"2026-05-12T10:00:33.038572Z","shell.execute_reply.started":"2026-05-12T10:00:32.999203Z","shell.execute_reply":"2026-05-12T10:00:33.036941Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 6: Response Templates — Mathematics\n# 4 response variants per topic:\n# visual_sequential | verbal_global | active_sensing | reflective_intuitive\n \nMATH_SAMPLES = [\n    {\n        \"topic\": \"Quadratic Equations\",\n        \"q\": \"Explain how to solve quadratic equations with examples.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Solving Quadratic Equations\n \n[DIAGRAM: Solution Methods Flowchart | graph TD\n    A[ax2+bx+c=0] --> B{Discriminant b2-4ac}\n    B -->|Greater than 0| C[Two real roots]\n    B -->|Equals 0| D[One repeated root]\n    B -->|Less than 0| E[No real roots]\n    C --> F[Use formula or factor]\n    D --> F\n    E --> G[Complex roots only]]\n \n**Step 1 — Write in Standard Form**\nax² + bx + c = 0\n \n**Step 2 — Check the Discriminant (b²−4ac)**\n[CHART: bar | {\"labels\":[\"D>0 two roots\",\"D=0 one root\",\"D<0 no real roots\"],\"values\":[60,20,20],\"title\":\"Distribution of Equation Types\"}]\n \n**Step 3 — Apply Quadratic Formula**\nx = (−b ± √(b²−4ac)) / 2a\n \n**Worked Example:** 2x² − 3x − 2 = 0\n- a=2, b=−3, c=−2\n- Discriminant = 9 + 16 = 25\n- x = (3 ± 5) / 4 → x = 2  or  x = −0.5 ✓\n \n[EXERCISE: medium | Solve x² + 5x + 6 = 0 using both factoring and the quadratic formula. Verify both methods give the same answer.]\"\"\",\n \n            \"verbal_global\": \"\"\"## Quadratic Equations — The Big Picture First\n \n**Why do quadratics matter?** Whenever something moves under gravity, a profit curve peaks, or a signal is filtered — that's a quadratic underneath. They are the first step beyond linear into the curved world.\n \nThe core structure is **ax² + bx + c = 0**, which describes a parabola. Solving it means finding where that curve crosses the x-axis — one, two, or zero times.\n \n### Three Solution Methods:\n**Factoring** — elegant when integer roots exist. Split b into two factors whose product equals ac.\n**Quadratic Formula** — x = (−b ± √(b²−4ac)) / 2a — works universally. Always reliable.\n**Completing the Square** — the conceptual foundation the formula derives from.\n \n### The Discriminant (b²−4ac) tells the full story:\n- Positive → two intersection points (two solutions)\n- Zero → curve just touches the axis (one double root)\n- Negative → curve floats above the axis (no real solutions)\n \n[NOTE: The discriminant is your quick preview. Calculate it before anything else — it tells you exactly what kind of answer to expect.]\n \n**Reflection:** Why can't a quadratic ever have exactly three real roots? Think about the geometry of a parabola.\"\"\",\n \n            \"active_sensing\": \"\"\"## Quadratic Equations — Hands-On Approach\n \n**The Formula (memorise this first, understand it second):**\nx = (−b ± √(b²−4ac)) / 2a\n \n**Apply it immediately to a concrete example:**\nEquation: 3x² + 7x + 2 = 0 → a=3, b=7, c=2\n1. Discriminant: 7² − 4(3)(2) = 49 − 24 = 25\n2. √25 = 5\n3. x = (−7 + 5)/6 = −1/3  OR  x = (−7 − 5)/6 = −2\n4. Check: 3(−1/3)² + 7(−1/3) + 2 = 0 ✓\n \n[EXERCISE: easy | Apply the quadratic formula to x² − 4x + 3 = 0. Show every arithmetic step.]\n[EXERCISE: medium | A ball follows h(t) = −5t² + 20t + 1. At what time does it hit the ground? Set h(t)=0 and solve.]\n[EXERCISE: hard | Derive the quadratic formula yourself by completing the square on ax² + bx + c = 0.]\"\"\",\n \n            \"reflective_intuitive\": \"\"\"## Quadratic Equations — The Deeper Pattern\n \nBefore jumping to mechanics, consider: **a quadratic is fundamentally a parabola**, and its roots are where that parabola meets the x-axis. Everything about the formula is a consequence of that geometric fact.\n \nThe formula x = (−b ± √(b²−4ac)) / 2a encodes:\n- −b/2a → the axis of symmetry (midpoint of the two roots)\n- ±√(b²−4ac)/2a → the symmetric deviation from that midpoint\n \nThis reveals a deep insight: **roots always come in symmetric pairs around −b/2a**. The discriminant measures how far apart they are. When it hits zero, the pair collapses to a single point.\n \n**Cross-domain connection:** This same structure appears in the quadratic formula for RLC circuits, the eigenvalue equation for 2×2 matrices, and characteristic equations in differential equations. Same algebra, different worlds.\n \n[NOTE: Completing the square transforms ax²+bx+c into a(x+p)²+q, making the vertex and symmetry directly visible.]\n \n**Reflection:** If someone handed you a quartic equation (degree 4), could you reduce it to two quadratics? Under what conditions would that work?\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Derivatives and Differentiation\",\n        \"q\": \"What is a derivative and how do I calculate one?\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Derivatives — Step by Step\n \n[DIAGRAM: Derivative as Slope | graph LR\n    A[Function f of x] --> B[Tangent Line at point x]\n    B --> C[Slope equals f-prime of x]\n    C --> D[Instantaneous Rate of Change]\n    D --> E[Applications: velocity, optimization, ML gradients]]\n \n**Step 1 — The Limit Definition**\nf'(x) = lim[h→0] ( f(x+h) − f(x) ) / h\n \n**Step 2 — Power Rule (covers 90% of cases)**\nd/dx (xⁿ) = n · xⁿ⁻¹\n \n[CHART: line | {\"labels\":[\"-2\",\"-1\",\"0\",\"1\",\"2\"],\"series\":[{\"name\":\"f(x)=x2\",\"values\":[4,1,0,1,4]},{\"name\":\"f'(x)=2x\",\"values\":[-4,-2,0,2,4]}],\"title\":\"f(x)=x2 and its derivative\"}]\n \n**Step 3 — Core Rules**\n| Rule     | Formula                         |\n|----------|---------------------------------|\n| Power    | d/dx(xⁿ) = nxⁿ⁻¹               |\n| Sum      | (f+g)' = f' + g'               |\n| Product  | (fg)' = f'g + fg'              |\n| Chain    | d/dx[f(g(x))] = f'(g(x))·g'(x)|\n \n[EXERCISE: easy | Differentiate f(x) = 4x³ − 2x² + 7x − 5 using the power rule.]\n[EXERCISE: medium | Use the chain rule to find d/dx [sin(x²)].]\"\"\",\n \n            \"verbal_global\": \"\"\"## Derivatives — From Rates of Change to Rules\n \n**The real-world framing:** Every time you ask \"how fast is this changing right now?\" — that's a derivative. Speed is the derivative of position. Marginal cost is the derivative of total cost. The gradient in machine learning is a derivative of the loss function.\n \nFormally, f'(x) gives the **instantaneous rate of change** of f at x. Computed by the limit: f'(x) = lim[h→0] (f(x+h) − f(x))/h — shrinking a slope interval until it becomes a tangent.\n \n**The Power Rule** (your most-used tool): d/dx(xⁿ) = nxⁿ⁻¹\n- d/dx(x²) = 2x\n- d/dx(x⁵) = 5x⁴\n- d/dx(constant) = 0 (constants don't change)\n \nYou combine the power rule with the sum, product, quotient, and chain rules to handle any function in calculus, physics, or machine learning.\n \n[NOTE: The chain rule is arguably the most important rule in all of calculus. It powers backpropagation in neural networks — every weight update in AI training depends on it.]\n \n**Reflection:** Why can't you divide (f(x+h)−f(x)) by h without taking a limit? What goes wrong if h is exactly 0?\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Probability and Statistics\",\n        \"q\": \"Explain probability with real-world examples.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Probability — From Zero to One\n \n[DIAGRAM: Probability Scale | graph LR\n    A[0.0 Impossible] --> B[0.25 Unlikely] --> C[0.5 Equal Chance] --> D[0.75 Likely] --> E[1.0 Certain]]\n \n**Core Formula:** P(Event) = Favourable Outcomes / Total Outcomes\n \n[CHART: bar | {\"labels\":[\"Coin heads\",\"Die rolls 6\",\"Card is Ace\",\"Sun rises\"],\"values\":[0.5,0.167,0.077,1.0],\"title\":\"Probability Examples\",\"ylabel\":\"Probability\"}]\n \n**Step 1 — Types of Events:**\n1. **Independent** → P(A and B) = P(A) × P(B)\n   Two coin flips: P(HH) = 0.5 × 0.5 = 0.25\n2. **Dependent** → P(A then B) = P(A) × P(B|A)\n   Drawing cards without replacement\n3. **Mutually Exclusive** → P(A or B) = P(A) + P(B)\n   Rolling 1 OR 6 = 1/6 + 1/6 = 1/3\n \n[EXERCISE: medium | A bag has 3 red and 5 blue balls. What is P(red then blue) drawn without replacement?]\"\"\",\n \n            \"verbal_global\": \"\"\"## Probability — Understanding Uncertainty\n \n**Why probability?** Every decision under uncertainty — weather forecasting, medical diagnosis, spam filters — relies on probability. It's the mathematics of confidence.\n \nProbability assigns a number between 0 and 1 to an outcome. P(Event) = Favourable/Total is the basic rule, but real-world probability is richer than coin flips.\n \n**The key insight about independence:** When events are independent, multiply their probabilities. When dependent, condition — P(B|A), the probability of B *given* A already happened.\n \n**Bayes' Theorem** — P(A|B) = P(B|A)·P(A) / P(B) — lets you update beliefs when new evidence arrives. This is how spam filters learn, how medical tests are interpreted, and how self-driving cars track objects.\n \n[NOTE: Statistical independence and mutual exclusivity are NOT the same thing. Two events can be exclusive without being independent.]\n \n**Reflection:** If a test is 99% accurate and a disease affects 1% of the population, what is the probability you actually have the disease if you test positive? The answer surprises most people.\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Linear Algebra — Matrices\",\n        \"q\": \"What are matrices and how do matrix operations work?\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Matrices — Visual Guide\n \n[DIAGRAM: Matrix Structure | graph TD\n    A[Matrix m x n] --> B[m rows]\n    A --> C[n columns]\n    B --> D[Element a-ij at row i col j]\n    A --> E[Square Matrix m equals n]\n    E --> F[Identity Matrix diagonal equals 1]\n    E --> G[Invertible if det not zero]]\n \n**Step 1 — Addition** (same shape only)\n[A+B]ᵢⱼ = Aᵢⱼ + Bᵢⱼ  — add element by element\n \n**Step 2 — Multiplication** (m×n) × (n×p) = (m×p)\n[AB]ᵢⱼ = Σₖ Aᵢₖ · Bₖⱼ  — row i of A dots column j of B\n \n**Step 3 — Transpose**\n(Aᵀ)ᵢⱼ = Aⱼᵢ  — flip rows and columns\n \n[CHART: bar | {\"labels\":[\"Addition\",\"Scalar Mult\",\"Transpose\",\"Matrix Mult\",\"Inverse\"],\"values\":[1,1,1,3,5],\"title\":\"Relative Complexity of Matrix Operations\"}]\n \n[EXERCISE: medium | If A is 2×3 and B is 3×4, what is the shape of AB? Calculate one element manually.]\"\"\",\n \n            \"verbal_global\": \"\"\"## Matrices — Organising Transformation\n \n**The big picture:** A matrix is a grid of numbers, but more importantly, it's a **linear transformation** — a rule for moving and stretching space. Multiplying a vector by a matrix rotates, scales, or shears it. This is why matrices power computer graphics, machine learning, and Google's PageRank.\n \nA matrix has m rows and n columns. The operations that matter: addition (element-wise, same shape required), multiplication (rows dot columns), and the inverse (undoes the transformation, only for square non-singular matrices).\n \n**The multiplication rule:** (m×n) × (n×p) = (m×p). Inner dimensions must match; outer dimensions form the result. Order matters — AB ≠ BA in general.\n \n[NOTE: The determinant of a square matrix tells you whether it's invertible. det=0 means the transformation collapses space to a lower dimension — no inverse exists.]\n \n**Reflection:** Neural network forward passes are sequences of matrix multiplications. What does training (adjusting weights) mean geometrically?\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Trigonometry Basics\",\n        \"q\": \"Explain sine, cosine, and tangent with examples.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Trigonometry — SOH CAH TOA\n \n**The Three Core Ratios:**\n- **sin θ** = Opposite / Hypotenuse\n- **cos θ** = Adjacent / Hypotenuse\n- **tan θ** = Opposite / Adjacent  (= sin/cos)\n \n**Memory Aid: SOH-CAH-TOA**\n \n[CHART: line | {\"labels\":[\"0 deg\",\"30 deg\",\"45 deg\",\"60 deg\",\"90 deg\"],\"series\":[{\"name\":\"sin\",\"values\":[0,0.5,0.707,0.866,1]},{\"name\":\"cos\",\"values\":[1,0.866,0.707,0.5,0]}],\"title\":\"sin and cos from 0 to 90 degrees\"}]\n \n**Key Angle Values:**\n| Angle | sin   | cos   | tan       |\n|-------|-------|-------|-----------|\n| 0°    | 0     | 1     | 0         |\n| 30°   | 0.500 | 0.866 | 0.577     |\n| 45°   | 0.707 | 0.707 | 1.000     |\n| 60°   | 0.866 | 0.500 | 1.732     |\n| 90°   | 1     | 0     | undefined |\n \n[EXERCISE: easy | A ladder leans against a wall at 60°. If the ladder is 5m long, how high does it reach?]\"\"\",\n \n            \"verbal_global\": \"\"\"## Trigonometry — Measuring Angles Through Ratios\n \n**Why trigonometry?** It answers: given an angle and one side of a right triangle, what are the other sides? This unlocks navigation, architecture, signal processing, and wave physics.\n \nsin(θ) = opposite/hypotenuse, cos(θ) = adjacent/hypotenuse, tan(θ) = sin/cos. These ratios are constant for any given angle — they don't depend on the triangle's size, only its shape.\n \n**The unit circle** extends trig beyond triangles: on a radius-1 circle, cos(θ) is the x-coordinate and sin(θ) the y-coordinate at angle θ. This is why sin and cos repeat every 360° — they trace the circle.\n \n**The Pythagorean identity** sin²(θ) + cos²(θ) = 1 is just the Pythagorean theorem applied to the unit circle. One fact, two notations.\n \n[NOTE: Sound, light, and AC electricity are all sinusoidal waves — described entirely by sin and cos. Trig isn't just for triangles; it's the language of oscillation.]\n \n**Reflection:** Why is tan(90°) undefined? Think about what opposite/adjacent means when adjacent shrinks to zero.\"\"\"\n        }\n    },\n]\n \nprint(f\"✅ {len(MATH_SAMPLES)} mathematics topics defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:33.041834Z","iopub.execute_input":"2026-05-12T10:00:33.042294Z","iopub.status.idle":"2026-05-12T10:00:33.097429Z","shell.execute_reply.started":"2026-05-12T10:00:33.042224Z","shell.execute_reply":"2026-05-12T10:00:33.095972Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 7: Response Templates — Science\n \nSCIENCE_SAMPLES = [\n    {\n        \"topic\": \"Photosynthesis\",\n        \"q\": \"Explain the process of photosynthesis step by step.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Photosynthesis — Stage by Stage\n \n[DIAGRAM: Photosynthesis Process | graph TD\n    SUN((Sunlight)) --> CHLO[Chlorophyll in Thylakoid]\n    CO2([CO2 from air]) --> CHLO\n    H2O([H2O from roots]) --> CHLO\n    CHLO --> LR[Light Reactions]\n    LR --> ATP[ATP + NADPH]\n    LR --> O2([O2 released to air])\n    ATP --> CC[Calvin Cycle in Stroma]\n    CO2 --> CC\n    CC --> GLU([Glucose])]\n \n**Overall Equation:**\n6CO₂ + 6H₂O + Light Energy → C₆H₁₂O₆ + 6O₂\n \n**Stage 1 — Light Reactions (Thylakoid)**\n1. Chlorophyll absorbs sunlight\n2. Water molecules split → releases O₂\n3. Produces energy carriers: ATP and NADPH\n \n**Stage 2 — Calvin Cycle (Stroma)**\n1. Uses ATP + NADPH from Stage 1\n2. Fixes CO₂ into 3-carbon intermediates\n3. Builds glucose (C₆H₁₂O₆)\n \n[CHART: pie | {\"labels\":[\"Heat loss\",\"Photosynthesis\",\"Reflection\"],\"values\":[85,5,10],\"title\":\"Fate of Sunlight in a Leaf\"}]\n \n[EXERCISE: medium | Why do plants wilt and slow photosynthesis on very hot days, even when there is plenty of water?]\"\"\",\n \n            \"verbal_global\": \"\"\"## Photosynthesis — Life Powered by Light\n \n**The grand picture:** Photosynthesis is how life on Earth captures energy from the sun and stores it in chemical bonds. Almost every calorie you eat traces back to a plant converting sunlight, water, and CO₂ into sugar. It is the engine of the biosphere.\n \nThe equation 6CO₂ + 6H₂O + light → C₆H₁₂O₆ + 6O₂ summarises a two-stage process:\n \n**Light Reactions** (thylakoid membranes) convert light energy into ATP and NADPH. Water is split as a side effect, releasing the oxygen we breathe.\n \n**Calvin Cycle** (stroma) uses those carriers to fix CO₂ — converting an inorganic gas into organic sugar. This is where atmospheric carbon becomes part of living matter.\n \n[NOTE: The oxygen in every breath you take came from photosynthesis splitting water molecules. This process has been running for over 2.7 billion years.]\n \n**Reflection:** If photosynthesis captures only 1–5% of sunlight, why does this seem so inefficient, yet why is it sufficient to power nearly all life on Earth?\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Newton's Laws of Motion\",\n        \"q\": \"Explain Newton's three laws of motion with real-world examples.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Newton's 3 Laws — Step by Step\n \n**Law 1 — Inertia**\nAn object stays at rest or moves at constant velocity unless a net external force acts on it.\n→ Example: A hockey puck slides indefinitely on frictionless ice.\n \n**Law 2 — F = ma**\nNet force = mass × acceleration. Double the mass → halve the acceleration for the same force.\n \n[CHART: bar | {\"labels\":[\"1 kg\",\"2 kg\",\"4 kg\",\"8 kg\"],\"values\":[10,5,2.5,1.25],\"title\":\"Acceleration from 10N force vs mass\",\"ylabel\":\"a (m/s2)\"}]\n \n**Law 3 — Action and Reaction**\nEvery action has an equal and opposite reaction.\n→ Swimming: you push water backward, water pushes you forward.\n \n[INFOGRAPHIC: Newton's Laws | {\"laws\":[{\"num\":\"1\",\"name\":\"Inertia\",\"formula\":\"F_net=0 then constant v\",\"example\":\"Seatbelt jerks when car stops\"},{\"num\":\"2\",\"name\":\"F=ma\",\"formula\":\"F = m x a\",\"example\":\"Heavier trolley needs more force\"},{\"num\":\"3\",\"name\":\"Action-Reaction\",\"formula\":\"F12 = minus F21\",\"example\":\"Rocket exhaust propels rocket up\"}]}]\n \n[EXERCISE: hard | A 1200 kg car accelerates from 0 to 27.8 m/s in 8 seconds. Calculate the net force required.]\"\"\",\n \n            \"verbal_global\": \"\"\"## Newton's Laws — Why Things Move (or Don't)\n \n**The revolution:** Before Newton, \"why does a moving object stop?\" seemed obvious — it just does. Newton showed the real question is the opposite: *why does anything stop at all?* Objects in motion naturally stay in motion. Forces change that.\n \n**Law 1 (Inertia)** is the foundation: no net force = no change in motion. Astronauts float at constant velocity in space because there's no air resistance or friction.\n \n**Law 2 (F = ma)** gives the precise relationship. It explains why a car engine (constant force) accelerates a loaded truck (large mass) more slowly than an empty one.\n \n**Law 3 (Action-Reaction)** is the most counter-intuitive: the wall pushes back equally hard when you push it. A rocket ejects mass backward; the reaction force drives it forward — no air needed.\n \n[NOTE: All three laws break down at very high speeds (needing relativity) and at atomic scales (needing quantum mechanics). Newton's laws are exact only in the classical domain — but extraordinarily accurate there.]\n \n**Reflection:** If action and reaction forces are always equal and opposite, why does anything ever accelerate? Think carefully about which object each force acts *on*.\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Chemical Bonding\",\n        \"q\": \"What are the types of chemical bonds and how do they form?\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Chemical Bonding — Types and Formation\n \n[DIAGRAM: Bond Types | graph TD\n    ATOMS[Atoms] --> IONIC[Ionic Bond]\n    ATOMS --> COVALENT[Covalent Bond]\n    ATOMS --> METALLIC[Metallic Bond]\n    IONIC --> IE[Metal + Non-metal: electron transfer]\n    COVALENT --> CE[Non-metal + Non-metal: electron sharing]\n    METALLIC --> ME[Metal + Metal: delocalised electrons]]\n \n**Step 1 — Ionic Bonds**\n- Metal gives electrons to non-metal\n- Opposite charges attract strongly\n- Example: Na⁺Cl⁻ (table salt)\n- Properties: high melting point, conducts when dissolved\n \n**Step 2 — Covalent Bonds**\n- Atoms share electron pairs (single/double/triple)\n- Example: H₂O, CO₂, N₂\n \n**Step 3 — Metallic Bonds**\n- Positive ions in a \"sea\" of free electrons\n- Explains conductivity and malleability\n \n[CHART: bar | {\"labels\":[\"Ionic\",\"Covalent polar\",\"Covalent non-polar\",\"Metallic\"],\"values\":[800,200,50,1000],\"title\":\"Typical Melting Points (deg C)\"}]\n \n[EXERCISE: medium | Predict the bond type in: MgO, HCl, O₂, and Fe. Explain your reasoning.]\"\"\",\n \n            \"verbal_global\": \"\"\"## Chemical Bonding — How Atoms Hold Together\n \n**The core principle:** Atoms form bonds to achieve lower energy states — typically by completing their outer electron shell. This drive for stability governs all chemistry.\n \n**Ionic bonding** — one atom fully transfers electrons to another. Between metals (which give electrons easily) and non-metals (which attract them). NaCl: sodium loses one electron to chlorine; both achieve stable configurations.\n \n**Covalent bonding** — atoms share electrons. Neither has sufficient electronegativity difference to steal from the other. Water, methane, and DNA are built on covalent bonds. Sharing can be equal (non-polar) or unequal (polar), with polar bonds driving much of biology.\n \n**Metallic bonding** — metal atoms pool outer electrons into a delocalised sea. This explains conductivity (free electrons carry charge) and malleability (electron cloud adjusts when layers slide).\n \n[NOTE: Electronegativity difference predicts bond type: large → ionic, moderate → polar covalent, small → non-polar covalent.]\n \n**Reflection:** Why do ionic compounds dissolve in water but not in oil? Think about what water molecules do to the charged ions.\"\"\"\n        }\n    },\n    {\n        \"topic\": \"DNA and Genetics\",\n        \"q\": \"How does DNA store and pass on genetic information?\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## DNA — Structure and Information Flow\n \n[DIAGRAM: Central Dogma | graph LR\n    DNA[DNA double helix] -->|Replication| DNA2[New DNA copy]\n    DNA -->|Transcription| RNA[mRNA strand]\n    RNA -->|Translation| PROT[Protein sequence]\n    PROT --> FUNC[Cell function and Trait]]\n \n**Step 1 — DNA Structure**\n- Double helix: two strands wound together\n- Complementary base pairing: A-T and G-C\n- Gene = specific base-pair sequence = protein recipe\n \n**Step 2 — Replication**\n1. Helicase unzips the two strands\n2. DNA polymerase reads each strand and builds the complement\n3. Two identical double helixes produced\n \n**Step 3 — Expression: Transcription → Translation**\n- Transcription: RNA polymerase copies a gene into mRNA\n- Translation: ribosomes read mRNA codons (3 bases) → amino acids → protein\n \n[CHART: bar | {\"labels\":[\"Human genes\",\"Bacterial genes\",\"Base pairs billions\"],\"values\":[21000,4300,3200],\"title\":\"Human vs Bacterial Genome Scale\"}]\n \n[EXERCISE: medium | If one DNA strand reads 5'-ATCGGC-3', write the complementary strand and the mRNA that would be transcribed.]\"\"\",\n \n            \"verbal_global\": \"\"\"## DNA — The Blueprint of Life\n \n**The fundamental insight:** DNA is an information storage molecule. It uses a four-letter alphabet (A, T, G, C) to encode instructions for building proteins — and proteins do virtually everything in a living cell.\n \nThe double helix (Watson, Crick, and Franklin, 1953) is elegant: two complementary strands held by base pairing (A-T, G-C). This complementarity is the key to faithful copying — each strand serves as a template for rebuilding the other.\n \n**Information flow — Central Dogma:** DNA → RNA → Protein. DNA is the archive (permanent, protected in the nucleus). mRNA is the working copy (temporary, single-stranded). Ribosomes translate mRNA into protein by reading three-base codons — 64 codons encode 20 amino acids, so the code is redundant.\n \n[NOTE: Retroviruses use reverse transcriptase to go RNA→DNA, and non-coding RNA plays regulatory roles. But DNA→RNA→protein remains the primary flow for gene expression.]\n \n**Reflection:** Why does having a redundant genetic code make organisms more robust to mutations? What kinds of mutations would be silent versus harmful?\"\"\"\n        }\n    },\n]\n \nprint(f\"✅ {len(SCIENCE_SAMPLES)} science topics defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:33.100937Z","iopub.execute_input":"2026-05-12T10:00:33.101329Z","iopub.status.idle":"2026-05-12T10:00:33.151446Z","shell.execute_reply.started":"2026-05-12T10:00:33.101299Z","shell.execute_reply":"2026-05-12T10:00:33.149815Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 8: Response Templates — Technology\n \nTECH_SAMPLES = [\n    {\n        \"topic\": \"How Machine Learning Works\",\n        \"q\": \"How does machine learning work? Explain for a complete beginner.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## How Machine Learning Works\n \n[DIAGRAM: ML Training Loop | graph LR\n    DATA[Labelled Training Data] --> FEAT[Feature Extraction]\n    FEAT --> MODEL[Model with weights w]\n    MODEL --> PRED[Predictions y-hat]\n    PRED --> LOSS[Loss Function]\n    LOSS --> GRAD[Gradients dL/dw]\n    GRAD --> UPDATE[Weight Update: w = w - lr * grad]\n    UPDATE --> MODEL]\n \n**Step 1 — Data** (labelled input-output pairs)\n1000 cat images labelled \"cat\", 1000 labelled \"dog\"\n \n**Step 2 — Model** (mathematical function with trainable parameters)\nA neural network with millions of adjustable weights\n \n**Step 3 — Training Loop**\n1. Feed a data batch through the model → get predictions\n2. Compare to true labels using a loss function\n3. Compute gradients (how to adjust each weight)\n4. Update weights (gradient descent)\n5. Repeat thousands of times\n \n[CHART: line | {\"labels\":[\"Epoch 1\",\"5\",\"20\",\"50\",\"100\"],\"series\":[{\"name\":\"Train Loss\",\"values\":[2.8,1.9,0.8,0.3,0.1]},{\"name\":\"Val Loss\",\"values\":[2.9,2.0,0.9,0.35,0.15]}],\"title\":\"Loss Reducing Over Training\"}]\n \n[EXERCISE: easy | Name three everyday ML applications you used today. For each, describe the model's input and output.]\"\"\",\n \n            \"verbal_global\": \"\"\"## Machine Learning — Teaching by Example\n \n**The paradigm shift:** Traditional programming is explicit rules. Machine learning inverts this: show the system thousands of examples and let it discover the rules itself.\n \nThe core loop: a model makes predictions on labelled data, compares them to true answers via a loss function, computes gradients showing how each parameter contributes to error, then adjusts parameters to reduce that error. Repeat over millions of examples. This is gradient descent — the algorithm behind nearly all modern AI.\n \n**Three paradigms:**\n- **Supervised** — labelled examples (cat/dog, spam/not-spam)\n- **Unsupervised** — find structure without labels (clustering, anomaly detection)\n- **Reinforcement** — learn through trial and reward (game-playing AI, robotics)\n \n[NOTE: A model that performs perfectly on training data but fails on new data is overfitting — it memorised the examples instead of learning the pattern. Generalisation is the real goal.]\n \n**Reflection:** Why does more training data usually improve a model, but not always? What other factors matter as much as data quantity?\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Python Programming Fundamentals\",\n        \"q\": \"Teach me Python programming from the basics.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Python Programming — Building Blocks\n \n[DIAGRAM: Python Execution Flow | graph TD\n    CODE[Python source .py] --> INTER[CPython Interpreter]\n    INTER --> BYTE[Bytecode .pyc]\n    BYTE --> PVM[Python Virtual Machine]\n    PVM --> OUTPUT[Program Output]]\n \n**Step 1 — Variables and Types**\n```python\nname   = \"Alice\"     # str\nage    = 17          # int\nscore  = 94.5        # float\npassed = True        # bool\n```\n \n**Step 2 — Control Flow**\n```python\nif score >= 90:\n    grade = \"A\"\nelif score >= 75:\n    grade = \"B\"\nelse:\n    grade = \"C\"\n```\n \n**Step 3 — Loops**\n```python\nfor i in range(5):\n    print(i * i)\n \ntotal = 0\nwhile total < 100:\n    total += 1\n```\n \n**Step 4 — Functions**\n```python\ndef calculate_bmi(weight_kg, height_m):\n    return weight_kg / (height_m ** 2)\n \nprint(calculate_bmi(70, 1.75))  # 22.86\n```\n \n[EXERCISE: medium | Write a function that takes a list of scores and returns a dict with keys 'mean', 'max', 'min', and 'grade_counts'.]\"\"\",\n \n            \"verbal_global\": \"\"\"## Python — The Language That Reads Like English\n \n**Why Python?** Designed with one philosophy: code should be readable. It uses indentation (not braces) to define structure, avoids semicolons, and reads closer to English than any major language. This is why it dominates education, data science, and AI.\n \n**Key concepts to master in order:**\nVariables and types (str, int, float, bool, list, dict) → Control flow (if/elif/else, for, while) → Functions (def, return, parameters) → Data structures (lists for sequences, dicts for key-value) → Modules (import — millions of libraries at your fingertips).\n \n**Python's superpower** is its ecosystem: NumPy for arrays, Pandas for data, Matplotlib for charts, Scikit-learn for ML, PyTorch for deep learning. One syntax unlocks all of modern data science.\n \n[NOTE: Python uses indentation for code blocks — a missing or extra space causes an IndentationError. Whitespace is meaningful. This forces readable code but trips up beginners.]\n \n**Reflection:** Why are list comprehensions — [x*2 for x in range(10)] — considered more \"Pythonic\" than equivalent for loops? What does idiomatic style signal about a language's philosophy?\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Computer Networks and the Internet\",\n        \"q\": \"How does the internet work? Explain networks and protocols.\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## How the Internet Works — Layer by Layer\n \n[DIAGRAM: TCP/IP Stack | graph TD\n    APP[Application Layer: HTTP SMTP DNS] --> TRANS[Transport Layer: TCP UDP]\n    TRANS --> NET[Network Layer: IP Routing]\n    NET --> LINK[Data Link Layer: Ethernet WiFi]\n    LINK --> PHYS[Physical Layer: Cables Fibre Radio]]\n \n**Step 1 — What happens when you type a URL**\n1. DNS lookup → converts domain name to IP address\n2. TCP connection → 3-way handshake establishes reliable channel\n3. HTTP request → browser asks server for page content\n4. HTTP response → server sends HTML/CSS/JS back\n5. Browser renders the page\n \n**Step 2 — Packets**\nData is split into small packets (~1500 bytes), routed independently, and reassembled at destination. This is why the internet is resilient.\n \n[CHART: bar | {\"labels\":[\"HTTP\",\"HTTPS\",\"FTP\",\"SMTP\",\"DNS\"],\"values\":[80,443,21,25,53],\"title\":\"Common Protocol Port Numbers\"}]\n \n[EXERCISE: medium | Trace every step from typing 'https://google.com' to seeing the page. Name the protocol and layer at each step.]\"\"\",\n \n            \"verbal_global\": \"\"\"## The Internet — A Global Packet-Switching Network\n \n**The revolutionary idea:** Instead of a dedicated circuit between every communicating pair (like old telephone networks), the internet breaks data into packets, routes each one independently, and reassembles them at the destination. This packet-switching design makes the network robust — no single failure disconnects everyone.\n \n**Protocols are the common language.** TCP/IP is foundational: IP handles addressing and routing (every device gets an IP address), TCP handles reliable ordered delivery (retransmits lost packets). On top of TCP/IP, HTTP (web), SMTP (email), and DNS (name-to-address translation) enable specific services.\n \n**The layered model** separates concerns: physical transmission, error correction, routing, and application logic are each handled independently. WiFi and fibre optic cables can both carry the same HTTP request because the application layer doesn't need to know what's underneath.\n \n[NOTE: HTTPS = HTTP + TLS encryption. Your browser and the server negotiate a shared secret key using asymmetric cryptography. All subsequent data is encrypted. The padlock icon represents this handshake.]\n \n**Reflection:** The internet has no central authority — no one \"runs\" it. How does a system with billions of independent devices manage to route packets reliably to the correct destination?\"\"\"\n        }\n    },\n    {\n        \"topic\": \"Artificial Intelligence and Large Language Models\",\n        \"q\": \"What are large language models and how do they generate text?\",\n        \"responses\": {\n            \"visual_sequential\": \"\"\"## Large Language Models — How They Work\n \n[DIAGRAM: LLM Architecture | graph LR\n    INPUT[Input tokens] --> EMBED[Token Embeddings]\n    EMBED --> ATTN[Multi-Head Self-Attention]\n    ATTN --> FFN[Feed-Forward Network]\n    FFN --> NORM[Layer Norm + Residual]\n    NORM --> ATTN\n    NORM --> OUT[Output: next token probabilities]]\n \n**Step 1 — Tokenisation**\nText split into tokens: \"Hello world\" → [\"Hello\", \" world\"]\n \n**Step 2 — Embeddings**\nEach token mapped to a high-dimensional vector (e.g. 4096 dimensions)\n \n**Step 3 — Transformer Blocks (repeated N times)**\n- Self-attention: each token looks at all others and updates its representation\n- Feed-forward: applies non-linear transformation\n \n**Step 4 — Output**\nFinal layer predicts probability distribution over vocabulary → sample next token\n \n[CHART: bar | {\"labels\":[\"GPT-3\",\"LLaMA 2 70B\",\"Gemma 7B\",\"Gemma 4 e4b\"],\"values\":[175,70,7,4],\"title\":\"Model Sizes in Billions of Parameters\"}]\n \n[EXERCISE: easy | Why does an LLM sometimes hallucinate facts? Based on the architecture above, reason through where errors could arise.]\"\"\",\n \n            \"verbal_global\": \"\"\"## Large Language Models — Predicting Language at Scale\n \n**The surprisingly simple objective:** An LLM is trained on one task — predict the next token in a sequence. Do this across hundreds of billions of tokens, with a large enough neural network, and the model learns grammar, facts, reasoning, and instruction-following.\n \n**The Transformer architecture** (Vaswani et al., 2017) is the engine. Its key innovation is self-attention: for every word in the input, the model computes how relevant every other word is, and updates each word's representation accordingly. This captures long-range dependencies — understanding that \"it\" in \"the dog ate its food\" refers to \"the dog\".\n \n**Training has two stages:** Pre-training on raw text (learn language and world knowledge), then fine-tuning with human feedback (RLHF) to make the model helpful and safe. Gemma 4 uses this pipeline.\n \n[NOTE: LLMs don't \"know\" facts the way a database does. They encode statistical patterns from training text. This is why they can generate plausible-sounding but wrong information — hallucination.]\n \n**Reflection:** If an LLM generates text one token at a time, each depending on what came before, is it \"thinking\", \"remembering\", or something else? What is the right mental model for what's actually happening?\"\"\"\n        }\n    },\n]\n \nprint(f\"✅ {len(TECH_SAMPLES)} technology topics defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-12T10:00:33.153834Z","iopub.execute_input":"2026-05-12T10:00:33.154233Z","iopub.status.idle":"2026-05-12T10:00:33.203931Z","shell.execute_reply.started":"2026-05-12T10:00:33.154200Z","shell.execute_reply":"2026-05-12T10:00:33.201876Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# STEP 9: Dataset Builder\n \ndef select_response_variant(profile: ILSProfile, responses: Dict) -> str:\n    \"\"\"Pick the best response variant based on ILS profile.\"\"\"\n    labels        = profile.get_labels()\n    is_visual     = \"Visual\"     in labels[\"input\"]\n    is_verbal     = \"Verbal\"     in labels[\"input\"]\n    is_sequential = \"Sequential\" in labels[\"understanding\"]\n    is_global     = \"Global\"     in labels[\"understanding\"]\n    is_active     = \"Active\"     in labels[\"processing\"]\n    is_reflective = \"Reflective\" in labels[\"processing\"]\n    is_intuitive  = \"Intuitive\"  in labels[\"perception\"]\n \n    if is_active     and \"active_sensing\"        in responses: return responses[\"active_sensing\"]\n    if is_reflective and is_intuitive            and \"reflective_intuitive\" in responses: return responses[\"reflective_intuitive\"]\n    if is_verbal     and is_global               and \"verbal_global\"        in responses: return responses[\"verbal_global\"]\n    if is_visual     and is_sequential           and \"visual_sequential\"    in responses: return responses[\"visual_sequential\"]\n    return list(responses.values())[0]\n \n \ndef apply_ils_adaptations(base_response: str, profile: ILSProfile) -> str:\n    \"\"\"Augment the base response with profile-specific additions.\"\"\"\n    labels    = profile.get_labels()\n    additions = []\n \n    if \"Sequential\" in labels[\"understanding\"] and \"Step\" not in base_response[:200]:\n        additions.append(\n            \"\\n\\n**Quick Review — Key Steps:**\\n\"\n            \"1. Read the definition\\n\"\n            \"2. Study the worked example\\n\"\n            \"3. Complete the exercise below\\n\"\n            \"4. Check your answer\"\n        )\n    if \"Global\" in labels[\"understanding\"] and \"[NOTE:\" not in base_response:\n        additions.append(\n            \"\\n\\n[NOTE: This concept is foundational — \"\n            \"understanding it unlocks several advanced topics in this subject and beyond.]\"\n        )\n    if \"Active\" in labels[\"processing\"] and \"[EXERCISE\" not in base_response:\n        additions.append(\n            \"\\n\\n[EXERCISE: easy | Before reading further, \"\n            \"try to solve a small version of this problem from first principles.]\"\n        )\n    if \"Reflective\" in labels[\"processing\"] and \"Reflection:\" not in base_response:\n        additions.append(\n            \"\\n\\n**Reflection:** Take a moment to connect this concept \"\n            \"to something you already know. What does this remind you of?\"\n        )\n \n    return base_response + \"\".join(additions)\n \n \ndef build_dataset() -> List[Dict]:\n    \"\"\"Build the complete fine-tuning dataset.\"\"\"\n    samples  = []\n    subjects = [\n        (\"mathematics\", MATH_SAMPLES),\n        (\"science\",     SCIENCE_SAMPLES),\n        (\"technology\",  TECH_SAMPLES),\n    ]\n \n    for subject, subject_samples in subjects:\n        for sample in subject_samples:\n            for profile in ILS_PROFILES:\n                labels   = profile.get_labels()\n                response = select_response_variant(profile, sample[\"responses\"])\n                response = apply_ils_adaptations(response, profile)\n                system   = build_system_prompt(profile, subject)\n \n                samples.append({\n                    \"messages\": [\n                        {\"role\": \"system\",    \"content\": system},\n                        {\"role\": \"user\",      \"content\": f\"[Subject: {subject}] [Topic: {sample['topic']}]\\n{sample['q']}\"},\n                        {\"role\": \"assistant\", \"content\": response}\n                    ],\n                    \"metadata\": {\n                        \"subject\":           subject,\n                        \"topic\":             sample[\"topic\"],\n                        \"ils_style_key\":     profile.get_style_key(),\n                        \"ils_processing\":    labels[\"processing\"],\n                        \"ils_perception\":    labels[\"perception\"],\n                        \"ils_input\":         labels[\"input\"],\n                        \"ils_understanding\": labels[\"understanding\"],\n                    }\n                })\n \n    random.shuffle(samples)\n    return samples\n \nprint(\"✅ Dataset builder functions defined\")","metadata":{"trusted":true,"execution":{"iopub